<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Events</h1>
            <p class="text-cream-75 mb-0">Schedule events for {{ tournament_name }}.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Schedule Event</h3>
          <form action="/{{ tournament_slug }}/events" method="post" class="row g-3">
            <div class="col-md-4">
              <label class="form-label text-cream-60">Event</label>
              <select class="form-select" name="event_id">
                {% for option in event_options %}
                  {% if option.id not in scheduled_ids %}
                  <option value="{{ option.id }}">{{ option.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Contact Type</label>
              <select class="form-select" name="contact_type">
                {% for option in contact_types %}
                <option value="{{ option }}">{{ option }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Status</label>
              <select class="form-select" name="status">
                {% for option in statuses %}
                <option value="{{ option }}">{{ option }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Location</label>
              <input class="form-control" name="location" placeholder="e.g. Court A" />
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Date & Time</label>
              <input class="form-control" type="datetime-local" name="event_time" />
            </div>
            <div class="col-md-6 d-flex align-items-end justify-content-end">
              <button class="btn btn-outline-light" type="submit">Add Event</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Scheduled Events</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Contact</th>
                  <th>Status</th>
                  <th>Location</th>
                  <th>Date & Time</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for item in events %}
                <tr>
                  <td>
                    <a class="fw-semibold text-decoration-none" href="/{{ tournament_slug }}/events/{{ item.id }}">{{ item.event_name }}</a>
                  </td>
                  <td>{{ item.contact_type }}</td>
                  <td>{{ item.status }}</td>
                  <td>{{ item.location | default(value="") }}</td>
                  <td>{{ item.event_time | default(value="") }}</td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editEventModal-{{ item.id }}">
                        Edit
                      </button>
                      <form action="/{{ tournament_slug }}/events/{{ item.id }}/delete" method="post">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="6" class="text-cream-60">No events scheduled yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for item in events %}
        <div class="modal fade" id="editEventModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/{{ tournament_slug }}/events/{{ item.id }}/update" method="post">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label text-muted">Event</label>
                      <select class="form-select" name="event_id">
                        {% for option in event_options %}
                        <option value="{{ option.id }}" {% if option.id == item.event_id %}selected{% endif %}>{{ option.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Contact Type</label>
                      <select class="form-select" name="contact_type">
                        {% for option in contact_types %}
                        <option value="{{ option }}" {% if option == item.contact_type %}selected{% endif %}>{{ option }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Status</label>
                      <select class="form-select" name="status">
                        {% for option in statuses %}
                        <option value="{{ option }}" {% if option == item.status %}selected{% endif %}>{{ option }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-12">
                      <label class="form-label text-muted">Location</label>
                      <input class="form-control" name="location" value="{{ item.location | default(value="") }}" />
                    </div>
                    <div class="col-12">
                      <label class="form-label text-muted">Date & Time</label>
                      <input class="form-control" type="datetime-local" name="event_time" value="{{ item.event_time | default(value="") }}" />
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
