<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Events</h1>
            <p class="text-cream-75 mb-0">Schedule events for {{ tournament_name }}.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Schedule Event</h3>
          <form action="/{{ tournament_slug }}/events" method="post" class="row g-3">
            <div class="col-md-4">
              <label class="form-label text-cream-60">Event</label>
              <select class="form-select" name="event_id">
                {% for option in event_options %}
                  <option value="{{ option.id }}">{{ option.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Contact Type</label>
              <select class="form-select js-contact-type" name="contact_type">
                {% for option in contact_types %}
                <option value="{{ option }}">{{ option }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Status</label>
              <select class="form-select" name="status">
                {% for option in statuses %}
                <option value="{{ option }}">{{ option }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Time</label>
              <select class="form-select" name="time_rule">
                <option value="1 round | 2 minutes" selected>1 round | 2 minutes</option>
                <option value="1 round | 1 minute">1 round | 1 minute</option>
                <option value="3 rounds | 1 minute">3 rounds | 1 minute</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Division</label>
              <select class="form-select" name="division_id">
                <option value="">Select division</option>
                {% for division in divisions %}
                <option value="{{ division.id }}">{{ division.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Weight Class</label>
              <select class="form-select" name="weight_class_id">
                <option value="">Select weight class</option>
                {% for weight in weight_classes %}
                <option value="{{ weight.id }}">{{ weight.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Location</label>
              <input class="form-control" name="location" placeholder="e.g. Court A" />
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Date & Time</label>
              <input class="form-control" type="datetime-local" name="event_time" />
            </div>
            <div class="col-12 js-contact-only d-none">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label text-cream-60">Point System</label>
                  <select class="form-select" name="point_system">
                    <option value="5-10 points">5-10 points</option>
                    <option value="Must 8/10 points">Must 8/10 points</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label text-cream-60">Draw System</label>
                  <select class="form-select" name="draw_system">
                    <option value="Extension">Extension</option>
                    <option value="First point Advantage">First point Advantage</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="col-md-6 d-flex align-items-end justify-content-end">
              <button class="btn btn-outline-light" type="submit">Add Event</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Scheduled Events</h3>

          <div class="mb-4">
            <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
              <div class="fw-semibold">Contact</div>
            </div>
            <div class="table-responsive">
              <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Location</th>
                    <th>Date & Time</th>
                    <th>Point System</th>
                    <th>Time</th>
                    <th>Division</th>
                    <th>Weight Class</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for item in contact_events %}
                  <tr>
                    <td>
                      <a class="fw-semibold text-decoration-none" href="/{{ tournament_slug }}/events/{{ item.id }}">{{ item.event_name }}</a>
                    </td>
                    <td>{{ item.status }}</td>
                    <td>{{ item.location | default(value="") }}</td>
                    <td>{{ item.event_time | default(value="") }}</td>
                    <td>{{ item.point_system | default(value="") }}</td>
                    <td>{{ item.time_rule | default(value="") }}</td>
                    <td>{{ item.division_name | default(value="") }}</td>
                    <td>{{ item.weight_class_label | default(value="") }}</td>
                    <td class="text-end">
                      <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editEventModal-{{ item.id }}">
                          Edit
                        </button>
                        <form action="/{{ tournament_slug }}/events/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  {% else %}
                  <tr>
                    <td colspan="9" class="text-cream-60">No contact events scheduled yet.</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
              <div class="fw-semibold">Non-Contact</div>
            </div>
            <div class="table-responsive">
              <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Location</th>
                    <th>Date & Time</th>
                    <th>Point System</th>
                    <th>Time</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for item in non_contact_events %}
                  <tr>
                    <td>
                      <a class="fw-semibold text-decoration-none" href="/{{ tournament_slug }}/events/{{ item.id }}">{{ item.event_name }}</a>
                    </td>
                    <td>{{ item.status }}</td>
                    <td>{{ item.location | default(value="") }}</td>
                    <td>{{ item.event_time | default(value="") }}</td>
                    <td>{{ item.point_system | default(value="") }}</td>
                    <td>{{ item.time_rule | default(value="") }}</td>
                    <td class="text-end">
                      <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editEventModal-{{ item.id }}">
                          Edit
                        </button>
                        <form action="/{{ tournament_slug }}/events/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  {% else %}
                  <tr>
                    <td colspan="7" class="text-cream-60">No non-contact events scheduled yet.</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </section>

        {% for item in events %}
        <div class="modal fade" id="editEventModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/{{ tournament_slug }}/events/{{ item.id }}/update" method="post">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label text-muted">Event</label>
                      <select class="form-select" name="event_id">
                        {% for option in event_options %}
                        <option value="{{ option.id }}" {% if option.id == item.event_id %}selected{% endif %}>{{ option.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Contact Type</label>
                      <select class="form-select js-contact-type" name="contact_type" data-contact-block="#edit-contact-{{ item.id }}">
                        {% for option in contact_types %}
                        <option value="{{ option }}" {% if option == item.contact_type %}selected{% endif %}>{{ option }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Status</label>
                      <select class="form-select" name="status">
                        {% for option in statuses %}
                        <option value="{{ option }}" {% if option == item.status %}selected{% endif %}>{{ option }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Time</label>
                      <select class="form-select" name="time_rule">
                        <option value="1 round | 2 minutes" {% if item.time_rule == "1 round | 2 minutes" %}selected{% endif %}>1 round | 2 minutes</option>
                        <option value="1 round | 1 minute" {% if item.time_rule == "1 round | 1 minute" %}selected{% endif %}>1 round | 1 minute</option>
                        <option value="3 rounds | 1 minute" {% if item.time_rule == "3 rounds | 1 minute" %}selected{% endif %}>3 rounds | 1 minute</option>
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Division</label>
                      <select class="form-select" name="division_id">
                        <option value="">Select division</option>
                        {% for division in divisions %}
                        <option value="{{ division.id }}" {% if item.division_id == division.id %}selected{% endif %}>{{ division.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Weight Class</label>
                      <select class="form-select" name="weight_class_id">
                        <option value="">Select weight class</option>
                        {% for weight in weight_classes %}
                        <option value="{{ weight.id }}" {% if item.weight_class_id == weight.id %}selected{% endif %}>{{ weight.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-12">
                      <label class="form-label text-muted">Location</label>
                      <input class="form-control" name="location" value="{{ item.location | default(value="") }}" />
                    </div>
                    <div class="col-12">
                      <label class="form-label text-muted">Date & Time</label>
                      <input class="form-control" type="datetime-local" name="event_time" value="{{ item.event_time | default(value="") }}" />
                    </div>
                    <div class="col-12 js-contact-only{% if item.contact_type != "Contact" %} d-none{% endif %}" id="edit-contact-{{ item.id }}">
                      <div class="row g-3">
                        <div class="col-md-4">
                          <label class="form-label text-muted">Point System</label>
                          <select class="form-select" name="point_system">
                            <option value="5-10 points" {% if item.point_system == "5-10 points" %}selected{% endif %}>5-10 points</option>
                            <option value="Must 8/10 points" {% if item.point_system == "Must 8/10 points" %}selected{% endif %}>Must 8/10 points</option>
                          </select>
                        </div>
                        <div class="col-md-4">
                          <label class="form-label text-muted">Draw System</label>
                          <select class="form-select" name="draw_system">
                            <option value="Extension" {% if item.draw_system == "Extension" %}selected{% endif %}>Extension</option>
                            <option value="First point Advantage" {% if item.draw_system == "First point Advantage" %}selected{% endif %}>First point Advantage</option>
                          </select>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
    <script>
      const contactSelectors = document.querySelectorAll(".js-contact-type");
      const toggleContactBlock = (select, block) => {
        if (!block) {
          return;
        }
        const isContact = String(select.value || "").toLowerCase() === "contact";
        block.classList.toggle("d-none", !isContact);
      };

      contactSelectors.forEach((select) => {
        const target = select.dataset.contactBlock
          ? document.querySelector(select.dataset.contactBlock)
          : select.closest("form")?.querySelector(".js-contact-only");
        toggleContactBlock(select, target);
        select.addEventListener("change", () => toggleContactBlock(select, target));
      });
    </script>
  </body>
</html>
