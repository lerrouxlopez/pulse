<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Teams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/admin_sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Teams</h1>
            <p class="text-cream-75 mb-0">Manage teams across all tournaments.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success" role="alert">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Create Team</h3>
          <form action="/admin/teams/create" method="post" class="row g-3">
            <div class="col-md-6">
              <label class="form-label text-cream-60">Tournament</label>
              <select class="form-select" name="tournament_id" required>
                {% for t in tournaments %}
                <option value="{{ t.id }}">{{ t.name }} ({{ t.slug }})</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Team Name</label>
              <input class="form-control" name="name" required />
            </div>
            <div class="col-12 d-flex justify-content-end">
              <button class="btn btn-outline-light" type="submit">Create</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">All Teams</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 80px">ID</th>
                  <th>Team</th>
                  <th>Tournament</th>
                  <th style="width: 110px">Members</th>
                  <th class="text-end" style="width: 280px">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for tm in teams %}
                <tr>
                  <td class="text-cream-60">#{{ tm.id }}</td>
                  <td class="fw-semibold">{{ tm.name }}</td>
                  <td>{{ tm.tournament_name }} <span class="text-cream-60 small">(/{{ tm.tournament_slug }}/)</span></td>
                  <td>{{ tm.members }}</td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <a class="btn btn-sm btn-outline-light" href="/admin/teams/{{ tm.tournament_id }}/{{ tm.id }}">Open</a>
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editTeamModal-{{ tm.id }}">Edit</button>
                      <form action="/admin/teams/{{ tm.tournament_id }}/{{ tm.id }}/delete" method="post" onsubmit="return confirm('Delete team and members?');">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="5" class="text-cream-60">No teams.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for tm in teams %}
        <div class="modal fade" id="editTeamModal-{{ tm.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Team #{{ tm.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/teams/{{ tm.tournament_id }}/{{ tm.id }}/update" method="post">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label text-muted">Team Name</label>
                      <input class="form-control" name="name" value="{{ tm.name }}" />
                    </div>
                    <div class="col-md-6">
                      <label class="form-label text-muted">Tournament</label>
                      <input class="form-control" value="{{ tm.tournament_name }} ({{ tm.tournament_slug }})" disabled />
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
  </body>
</html>

