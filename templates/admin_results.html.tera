<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Results</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/admin_sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Results</h1>
            <p class="text-cream-75 mb-0">Read-only results view for any tournament.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-2">Tournament</h3>
          <form method="get" action="/admin/results" class="d-flex flex-wrap gap-2 align-items-center">
            <select class="form-select" name="tournament_id" onchange="this.form.submit()">
              {% for t in tournaments %}
              <option value="{{ t.id }}" {% if selected_tournament_id and t.id == selected_tournament_id %}selected{% endif %}>
                {{ t.name }} ({{ t.slug }})
              </option>
              {% endfor %}
            </select>
            <noscript><button class="btn btn-outline-light" type="submit">Load</button></noscript>
          </form>
        </section>

        {% if champion_teams and champion_teams | length > 0 %}
        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Champion Team(s)</h3>
          <div class="d-flex flex-wrap gap-2">
            {% for team in champion_teams %}
            <span class="badge text-bg-light">{{ team.team_name }} ({{ team.wins }} wins)</span>
            {% endfor %}
          </div>
        </section>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Team Leaderboard</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 80px">#</th>
                  <th>Team</th>
                  <th style="width: 120px">Wins</th>
                </tr>
              </thead>
              <tbody>
                {% for row in team_leaderboard %}
                <tr>
                  <td class="text-cream-60">{{ loop.index }}</td>
                  <td class="fw-semibold">{{ row.team_name }}</td>
                  <td>{{ row.wins }}</td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="3" class="text-cream-60">No leaderboard data yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Event Winners</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Division</th>
                  <th>Weight</th>
                  <th>Winner</th>
                  <th>Winner Team</th>
                </tr>
              </thead>
              <tbody>
                {% for w in event_winners %}
                <tr>
                  <td class="fw-semibold">{{ w.event_name }}</td>
                  <td>{{ w.division_name | default(value="") }}</td>
                  <td>{{ w.weight_class_label | default(value="") }}</td>
                  <td>{{ w.winner_name }}</td>
                  <td>{{ w.winner_team | default(value="") }}</td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="5" class="text-cream-60">No finished events with winners.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Match Results</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 90px">Match</th>
                  <th>Event</th>
                  <th>Label</th>
                  <th style="width: 110px">Status</th>
                  <th style="width: 200px">Winner</th>
                  <th style="width: 140px">Score</th>
                </tr>
              </thead>
              <tbody>
                {% for m in match_results %}
                <tr>
                  <td class="text-cream-60">#{{ m.match_id }}</td>
                  <td>{{ m.event_name }}</td>
                  <td class="fw-semibold">{{ m.label }}</td>
                  <td>{{ m.status }}</td>
                  <td>{{ m.winner | default(value="") }}</td>
                  <td>{{ m.red_total_score }} - {{ m.blue_total_score }}</td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="6" class="text-cream-60">No finished matches.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <script src="/static/sidebar.js"></script>
  </body>
</html>

