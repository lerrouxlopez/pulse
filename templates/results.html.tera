<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Results</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Results</h1>
            <p class="text-cream-75 mb-0">Tournament results for {{ tournament_name }}.</p>
          </div>
          {% if can_reset_results %}
          <form action="/{{ tournament_slug }}/results/reset" method="post" onsubmit="return confirm('Recalculate tournament results now?');">
            <button class="btn btn-outline-light" type="submit">Reset Results</button>
          </form>
          {% endif %}
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4 text-ink">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
            <h3 class="fw-semibold mb-0">Overall Champion Team</h3>
            <div class="text-muted small">Based on number of event winners per team.</div>
          </div>

          {% if champion_teams | length > 0 %}
            <div class="row g-3">
              {% for team in champion_teams %}
              <div class="col-12 col-md-6 col-lg-4">
                <div class="p-3 border rounded bg-white">
                  <div class="d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">{{ team.team_name }}</div>
                    <span class="badge text-bg-dark">{{ team.wins }} wins</span>
                  </div>
                </div>
              </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="text-muted">No champions yet. Finish events to see results.</div>
          {% endif %}

          {% if team_leaderboard | length > 0 %}
          <div class="mt-4">
            <h4 class="fw-semibold mb-2">Team Leaderboard</h4>
            <div class="table-responsive">
              <table class="table table-striped align-middle mb-0">
                <thead>
                  <tr>
                    <th scope="col">Team</th>
                    <th scope="col" class="text-end">Wins</th>
                  </tr>
                </thead>
                <tbody>
                  {% for row in team_leaderboard %}
                  <tr>
                    <td>{{ row.team_name }}</td>
                    <td class="text-end">{{ row.wins }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
          {% endif %}
        </section>

        <section class="panel mb-4 text-ink">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Event Winners</h3>
          </div>
          <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Event</th>
                  <th scope="col">Gender Division</th>
                  <th scope="col">Weight Class</th>
                  <th scope="col">Winner</th>
                  <th scope="col">Team</th>
                </tr>
              </thead>
              <tbody>
                {% for item in event_winners %}
                <tr>
                  <td>{{ item.event_name }}</td>
                  <td>{{ item.division_name | default(value="") }}</td>
                  <td>{{ item.weight_class_label | default(value="") }}</td>
                  <td class="fw-semibold">{{ item.winner_name }}</td>
                  <td>{{ item.winner_team | default(value="") }}</td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="5" class="text-muted">No event winners yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel text-ink">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Match Results</h3>
            <form method="get" action="/{{ tournament_slug }}/results" class="d-flex align-items-center gap-2">
              <input
                class="form-control form-control-sm"
                style="max-width: 320px"
                name="q"
                value="{{ match_results_query | default(value='') }}"
                placeholder="Search matches..."
                aria-label="Search matches"
              />
              <button class="btn btn-outline-dark btn-sm" type="submit">Search</button>
              {% if match_results_query %}
              <a class="btn btn-outline-secondary btn-sm" href="/{{ tournament_slug }}/results">Clear</a>
              {% endif %}
            </form>
          </div>
          <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Event</th>
                  <th scope="col">Match</th>
                  <th scope="col">Status</th>
                  <th scope="col">Winner</th>
                </tr>
              </thead>
              <tbody>
                {% for item in match_results %}
                <tr>
                  <td>
                    <a
                      class="js-match-result-link"
                      href="#"
                      data-bs-toggle="modal"
                      data-bs-target="#matchResultModal"
                      data-match-id="{{ item.match_id }}"
                    >{{ item.event_name }}</a>
                  </td>
                  <td>{{ item.label }}</td>
                  <td>{{ item.status }}</td>
                  <td>{{ item.winner | default(value="") }}</td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="4" class="text-muted">No finished matches yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-3">
            <div class="text-muted small">
              Showing {{ match_results | length }} of {{ match_results_total }}{% if match_results_query %} results for "{{ match_results_query }}"{% endif %}.
              Page {{ match_results_page }} of {{ match_results_pages }}.
            </div>
            <nav aria-label="Match results pagination">
              <ul class="pagination pagination-sm mb-0">
                <li class="page-item {% if not match_results_has_prev %}disabled{% endif %}">
                  <a class="page-link" href="/{{ tournament_slug }}/results?page={{ match_results_page - 1 }}{% if match_results_query %}&q={{ match_results_query }}{% endif %}">Prev</a>
                </li>
                {% for p in match_results_page_numbers %}
                <li class="page-item {% if p == match_results_page %}active{% endif %}">
                  <a class="page-link" href="/{{ tournament_slug }}/results?page={{ p }}{% if match_results_query %}&q={{ match_results_query }}{% endif %}">{{ p }}</a>
                </li>
                {% endfor %}
                <li class="page-item {% if not match_results_has_next %}disabled{% endif %}">
                  <a class="page-link" href="/{{ tournament_slug }}/results?page={{ match_results_page + 1 }}{% if match_results_query %}&q={{ match_results_query }}{% endif %}">Next</a>
                </li>
              </ul>
            </nav>
          </div>
        </section>
      </main>
    </div>

    <div class="modal fade" id="matchResultModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content text-ink">
          <div class="modal-header">
            <div class="min-w-0">
              <h5 class="modal-title mb-0" id="matchResultModalTitle">Match Details</h5>
              <div class="text-muted small" id="matchResultModalSubtitle"></div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div id="matchResultModalBody" class="text-muted">Loading...</div>
          </div>
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
    <script>
      const modalEl = document.getElementById("matchResultModal");
      const titleEl = document.getElementById("matchResultModalTitle");
      const subtitleEl = document.getElementById("matchResultModalSubtitle");
      const bodyEl = document.getElementById("matchResultModalBody");

      const escapeHtml = (value) => {
        const div = document.createElement("div");
        div.textContent = String(value ?? "");
        return div.innerHTML;
      };

      const renderRound = (round) => {
        const judges = Array.isArray(round.judges) ? round.judges : [];
        const rows = judges
          .map((j) => {
            const name = escapeHtml(j.judge_name);
            const red = Number(j.red_score ?? 0);
            const blue = Number(j.blue_score ?? 0);
            const order = Number(j.judge_order ?? 0);
            return `
              <tr>
                <td class="text-muted">#${order}</td>
                <td>${name}</td>
                <td class="text-end fw-semibold">${red}</td>
                <td class="text-end fw-semibold">${blue}</td>
              </tr>
            `;
          })
          .join("");

        return `
          <section class="mb-4">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <div class="fw-semibold">Round ${Number(round.fight_round ?? 1)}</div>
              <div class="small text-muted">Totals: <span class="fw-semibold">${Number(round.red_total ?? 0)}</span> - <span class="fw-semibold">${Number(round.blue_total ?? 0)}</span></div>
            </div>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                  <tr>
                    <th style="width:64px">#</th>
                    <th>Judge</th>
                    <th class="text-end">Red</th>
                    <th class="text-end">Blue</th>
                  </tr>
                </thead>
                <tbody>
                  ${rows || `<tr><td colspan="4" class="text-muted">No judge assignments yet.</td></tr>`}
                </tbody>
              </table>
            </div>
          </section>
        `;
      };

      if (modalEl) {
        modalEl.addEventListener("show.bs.modal", async (event) => {
          const trigger = event.relatedTarget;
          const matchId = trigger && trigger.getAttribute ? trigger.getAttribute("data-match-id") : null;
          if (!matchId) return;

          titleEl.textContent = "Match Details";
          subtitleEl.textContent = "";
          bodyEl.textContent = "Loading...";

          try {
            const res = await fetch(`/{{ tournament_slug }}/results/matches/${encodeURIComponent(matchId)}`, {
              headers: { "Accept": "application/json" },
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();

            titleEl.textContent = data.event_name ? `Match Details: ${data.event_name}` : "Match Details";
            const winner = data.winner ? `Winner: ${data.winner}` : "";
            subtitleEl.textContent = [data.label, data.status, winner].filter(Boolean).join(" | ");

            const rounds = Array.isArray(data.rounds) ? data.rounds : [];
            bodyEl.innerHTML = rounds.map(renderRound).join("") || `<div class="text-muted">No rounds found.</div>`;
          } catch (err) {
            bodyEl.innerHTML = `<div class="text-danger">Failed to load match details.</div>`;
          }
        });
      }
    </script>
  </body>
</html>
