<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream">
    <main class="container py-5" style="max-width: 520px;">
      <div class="panel">
        <h1 class="fw-bold mb-2">Admin Workspace</h1>
        <p class="text-cream-75 mb-4">Sign in to manage the entire system.</p>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}

        <form action="/admin/login" method="post" class="row g-3">
          <div class="col-12">
            <label class="form-label text-cream-60">Email</label>
            <input class="form-control" type="email" name="email" autocomplete="username" required />
          </div>
          <div class="col-12">
            <label class="form-label text-cream-60">Password</label>
            <input class="form-control" type="password" name="password" autocomplete="current-password" required />
          </div>
          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-outline-light" type="submit">Sign in</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>

