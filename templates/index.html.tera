<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Martial Arts Tournament</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream">
    <header class="hero-section position-relative overflow-hidden">
      <nav class="navbar navbar-expand-lg py-4">
        <div class="container">
          <a class="navbar-brand fw-bold text-cream d-flex align-items-center gap-2" href="/">
            <img
              src="/static/logo-dark.png"
              class="brand-logo logo-dark"
              alt="Pulse logo dark"
            />
            <img
              src="/static/logo-light.png"
              class="brand-logo logo-light"
              alt="Pulse logo light"
            />
            <span>Pulse</span>
          </a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto gap-3">
              <li class="nav-item">
                <a class="nav-link text-cream" href="#features">Features</a>
              </li>
              <li class="nav-item">
                <a class="nav-link text-cream" href="#flow">Flow</a>
              </li>
              <li class="nav-item">
                <a class="btn btn-primary shadow-glow" href="/auth">Get Started</a>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <div class="container py-5">
        <div class="row align-items-center g-5">
          <div class="col-lg-6">
            <p class="badge text-bg-light text-ink mb-3">Martial Arts Tournament OS</p>
            <h1 class="display-4 fw-bold">
              Run brackets with precision, not spreadsheets.
            </h1>
            <p class="lead text-cream-75">
              Pulse keeps your fighters, mats, and match flow synced in one
              place. Organize divisions, print brackets, and keep spectators in
              the loop with live updates.
            </p>
            <div class="d-flex flex-wrap gap-3 mt-4">
              <a class="btn btn-primary btn-lg shadow-glow" href="/auth">Get Started</a>
              <a class="btn btn-outline-light btn-lg" href="#features"
                >See how it works</a
              >
            </div>
            <div class="d-flex gap-4 mt-4 small text-cream-75">
              <span>Fast check-in</span>
              <span>Brackets + pools</span>
              <span>Live scoring</span>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="hero-card p-4 p-md-5">
              <div class="d-flex justify-content-between mb-4">
                <span class="pill">Division A</span>
                <span class="pill">Mat 2</span>
              </div>
              <h3 class="fw-semibold mb-3">Finals - Lightweight</h3>
              <div class="matchup">
                <div>
                  <p class="mb-1">Jade Kim</p>
                  <small class="text-cream-60">Dojo North</small>
                </div>
                <span class="score">7</span>
              </div>
              <div class="matchup">
                <div>
                  <p class="mb-1">Andre Ruiz</p>
                  <small class="text-cream-60">Storm Fight Lab</small>
                </div>
                <span class="score">6</span>
              </div>
              <button class="btn btn-outline-light w-100 mt-4">
                Advance Winner
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section id="features" class="py-5">
      <div class="container">
        <div class="row mb-4">
          <div class="col-lg-7">
            <h2 class="fw-bold">Everything your tournament team needs.</h2>
            <p class="text-cream-75">
              Built for busy event crews. Switch views by mat, find fighters
              instantly, and keep brackets accurate from weigh-in to awards.
            </p>
          </div>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="feature-card h-100">
              <h5 class="fw-semibold">Roster Control</h5>
              <p class="text-cream-75">
                Import athletes, assign divisions, and flag no-shows in seconds.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card h-100">
              <h5 class="fw-semibold">Bracket Engine</h5>
              <p class="text-cream-75">
                Single elimination, round robin, or pools with automatic seeding.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card h-100">
              <h5 class="fw-semibold">Live Display</h5>
              <p class="text-cream-75">
                Share real-time results on TV screens or mobile dashboards.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="flow" class="py-5 flow-section">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-lg-6">
            <div class="stack-card">
              <h4 class="fw-semibold">Event Flow</h4>
              <ol class="list-unstyled mt-3 mb-0">
                <li class="flow-step">
                  <span>1</span>
                  <p class="mb-0">Create divisions and mats</p>
                </li>
                <li class="flow-step">
                  <span>2</span>
                  <p class="mb-0">Auto-seed brackets</p>
                </li>
                <li class="flow-step">
                  <span>3</span>
                  <p class="mb-0">Run matches with live scoring</p>
                </li>
              </ol>
            </div>
          </div>
          <div class="col-lg-6">
            <h2 class="fw-bold">Design for staff, not software.</h2>
            <p class="text-cream-75">
              Pulse keeps the action moving with a clean control room. Assign
              operators per mat, publish results automatically, and handle
              updates without downtime.
            </p>
            <ul class="list-unstyled text-cream-75">
              <li class="mb-2">Instant bracket recalculation</li>
              <li class="mb-2">Mat view with match timer</li>
              <li>PDF exports for officials</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="cta" class="py-5">
      <div class="container">
        <div class="cta-card text-center p-5">
          <h2 class="fw-bold mb-3">Ready to build your next event?</h2>
          <p class="text-cream-75 mb-4">
            Spin up a tournament dashboard in minutes and keep the crowd on the
            edge of the mat.
          </p>
          <a class="btn btn-primary btn-lg shadow-glow" href="/auth">Get Started</a>
        </div>
      </div>
    </section>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
