<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Tournaments</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/admin_sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Tournaments</h1>
            <p class="text-cream-75 mb-0">Create and manage tournaments.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success" role="alert">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Create Tournament</h3>
          <form action="/admin/tournaments/create" method="post" class="row g-3">
            <div class="col-md-5">
              <label class="form-label text-cream-60">Name</label>
              <input class="form-control" name="name" required />
            </div>
            <div class="col-md-4">
              <label class="form-label text-cream-60">Owner (system user)</label>
              <select class="form-select" name="owner_user_id" required>
                {% for u in owners %}
                <option value="{{ u.id }}">{{ u.email }} ({{ u.name }})</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Slug (optional)</label>
              <input class="form-control" name="slug" placeholder="auto" />
            </div>
            <div class="col-12 d-flex justify-content-end">
              <button class="btn btn-outline-light" type="submit">Create</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">All Tournaments</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 80px">ID</th>
                  <th>Name</th>
                  <th style="width: 180px">Slug</th>
                  <th style="width: 220px">Owner</th>
                  <th style="width: 120px">Setup</th>
                  <th class="text-end" style="width: 260px">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for t in tournaments %}
                <tr>
                  <td class="text-cream-60">#{{ t.id }}</td>
                  <td class="fw-semibold">{{ t.name }}</td>
                  <td><code>/{{ t.slug }}/</code></td>
                  <td>
                    {% if t.owner_label %}
                      {{ t.owner_label }}
                    {% else %}
                      <span class="text-cream-60 small">User #{{ t.user_id }}</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if t.is_setup %}
                      <span class="badge text-bg-success">setup</span>
                    {% else %}
                      <span class="badge text-bg-secondary">not setup</span>
                    {% endif %}
                  </td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editTournamentModal-{{ t.id }}">Edit</button>
                      <form action="/admin/tournaments/{{ t.id }}/delete" method="post" onsubmit="return confirm('Delete tournament and all related data? This cannot be undone.');">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="6" class="text-cream-60">No tournaments.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for t in tournaments %}
        <div class="modal fade" id="editTournamentModal-{{ t.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Tournament #{{ t.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/tournaments/{{ t.id }}/update" method="post">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-md-5">
                      <label class="form-label text-muted">Name</label>
                      <input class="form-control" name="name" value="{{ t.name }}" />
                    </div>
                    <div class="col-md-4">
                      <label class="form-label text-muted">Owner (system user)</label>
                      <select class="form-select" name="owner_user_id">
                        {% for u in owners %}
                        <option value="{{ u.id }}" {% if u.id == t.user_id %}selected{% endif %}>{{ u.email }} ({{ u.name }})</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Slug</label>
                      <input class="form-control" name="slug" value="{{ t.slug }}" />
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
  </body>
</html>
