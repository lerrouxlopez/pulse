<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Dashboard</h1>
            <p class="text-cream-75 mb-0">
              {{ tournament_name }}. Welcome back, {{ name }}.
            </p>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2">
            <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/events">Schedule events</a>
            <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/matches">Matches</a>
            <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/teams">Teams</a>
            <a class="btn btn-primary btn-sm shadow-glow" href="/{{ tournament_slug }}/results">Results</a>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <section class="row g-3 mb-4">
          <div class="col-md-3">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Scheduled events</p>
              <div class="d-flex align-items-end justify-content-between gap-2">
                <h2 class="mb-0 fw-bold">{{ counts.scheduled_events }}</h2>
                <span class="pill">{{ counts_events_finished }} finished</span>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Matches</p>
              <div class="d-flex align-items-end justify-content-between gap-2">
                <h2 class="mb-0 fw-bold">{{ counts.matches }}</h2>
                <span class="pill">{{ counts_matches_finished }} finished</span>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Teams</p>
              <div class="d-flex align-items-end justify-content-between gap-2">
                <h2 class="mb-0 fw-bold">{{ counts.teams }}</h2>
                <span class="pill">Roster {{ counts.members }}</span>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Outcomes</p>
              <div class="d-flex align-items-end justify-content-between gap-2">
                <h2 class="mb-0 fw-bold">{{ outcomes_count }}</h2>
                <span class="pill">Recorded</span>
              </div>
            </div>
          </div>
        </section>

        <section class="row g-3 mb-4">
          <div class="col-lg-6">
            <div class="panel">
              <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
                <h3 class="fw-semibold mb-0">Events</h3>
                <span class="text-cream-60 small">Status and type</span>
              </div>
              <div class="dashboard-chart-grid">
                <div class="dashboard-chart">
                  <canvas id="chartEventsStatus" height="180"></canvas>
                </div>
                <div class="dashboard-chart">
                  <canvas id="chartEventsType" height="180"></canvas>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="panel">
              <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
                <h3 class="fw-semibold mb-0">Matches</h3>
                <span class="text-cream-60 small">Status and activity</span>
              </div>
              <div class="dashboard-chart-grid">
                <div class="dashboard-chart">
                  <canvas id="chartMatchesStatus" height="180"></canvas>
                </div>
                <div class="dashboard-chart">
                  <canvas id="chartMatchesActivity" height="180"></canvas>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="row g-3 mb-4">
          <div class="col-lg-7">
            <div class="panel">
              <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
                <h3 class="fw-semibold mb-0">Scheduling Activity (30 days)</h3>
                <span class="text-cream-60 small">Created events and matches</span>
              </div>
              <div class="dashboard-chart">
                <canvas id="chartActivity" height="120"></canvas>
              </div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="panel">
              <div class="d-flex align-items-center justify-content-between mb-3">
                <h3 class="fw-semibold mb-0">Upcoming</h3>
                <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/events">View events</a>
              </div>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>When</th>
                      <th class="text-end">Link</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in upcoming %}
                    <tr>
                      <td>
                        <div class="fw-semibold">{{ row.event_name }}</div>
                        <div class="text-cream-60 small">
                          {{ row.contact_type }}
                          {% if row.division_name %} | {{ row.division_name }}{% endif %}
                          {% if row.weight_class_name %} | {{ row.weight_class_name }}{% endif %}
                        </div>
                      </td>
                      <td class="small">
                        {{ row.event_time | default(value="") }}
                        {% if row.location %}<div class="text-cream-60">{{ row.location }}</div>{% endif %}
                      </td>
                      <td class="text-end">
                        <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/events/{{ row.scheduled_event_id }}">Open</a>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="3" class="text-cream-60">No upcoming events with a date/time set.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        <section class="row g-3 mb-4">
          <div class="col-lg-7">
            <div class="panel">
              <div class="d-flex align-items-center justify-content-between mb-3">
                <h3 class="fw-semibold mb-0">Recent Matches</h3>
                <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/matches">View matches</a>
              </div>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>Status</th>
                      <th>Mat</th>
                      <th class="text-end">Link</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in recent_matches %}
                    <tr>
                      <td class="fw-semibold">{{ row.event_name }}</td>
                      <td><span class="pill">{{ row.status }}</span></td>
                      <td>{{ row.mat | default(value="") }}</td>
                      <td class="text-end">
                        <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/matches/{{ row.match_id }}">Open</a>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="4" class="text-cream-60">No matches yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="panel">
              <div class="d-flex align-items-center justify-content-between mb-3">
                <h3 class="fw-semibold mb-0">Event Results</h3>
                <a class="btn btn-outline-light btn-sm" href="/{{ tournament_slug }}/results">View results</a>
              </div>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>Winner</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in outcomes %}
                    <tr>
                      <td class="fw-semibold">
                        {{ item.event_name }}
                        {% if item.division_name or item.weight_class_label %}
                        <div class="text-cream-60 small">
                          {{ item.division_name | default(value="") }} {{ item.weight_class_label | default(value="") }}
                        </div>
                        {% endif %}
                      </td>
                      <td>{{ item.winner_name | default(value="") }}</td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No outcomes yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="/static/sidebar.js"></script>
    <script>
      (() => {
        const palette = {
          primary: getComputedStyle(document.documentElement).getPropertyValue("--theme-primary").trim() || "#2d62ff",
          accent: getComputedStyle(document.documentElement).getPropertyValue("--theme-accent").trim() || "#ff6b35",
          ink: "#0b0f1a",
          grid: "rgba(17, 24, 39, 0.10)",
          text: "rgba(17, 24, 39, 0.85)",
        };

        const data = {{ dashboard_json | safe }};

        const baseOptions = {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: palette.text } },
            tooltip: { enabled: true },
          },
        };

        const doughnut = (id, labels, values) => {
          const el = document.getElementById(id);
          if (!el) return;
          const colors = [
            palette.primary,
            palette.accent,
            "rgba(16, 185, 129, 0.85)",
            "rgba(244, 63, 94, 0.78)",
            "rgba(59, 130, 246, 0.70)",
            "rgba(148, 163, 184, 0.80)",
          ];
          new Chart(el, {
            type: "doughnut",
            data: {
              labels,
              datasets: [{ data: values, backgroundColor: labels.map((_, i) => colors[i % colors.length]) }],
            },
            options: {
              ...baseOptions,
              cutout: "62%",
            },
          });
        };

        doughnut("chartEventsStatus", data.events_by_status.labels, data.events_by_status.values);
        doughnut("chartEventsType", data.events_by_type.labels, data.events_by_type.values);
        doughnut("chartMatchesStatus", data.matches_by_status.labels, data.matches_by_status.values);

        const matchesActivity = document.getElementById("chartMatchesActivity");
        if (matchesActivity) {
          new Chart(matchesActivity, {
            type: "bar",
            data: {
              labels: data.matches_series.labels,
              datasets: [{
                label: "Matches created",
                data: data.matches_series.values,
                backgroundColor: "rgba(45, 98, 255, 0.35)",
                borderColor: palette.primary,
                borderWidth: 1,
              }],
            },
            options: {
              ...baseOptions,
              scales: {
                x: { ticks: { color: palette.text, maxRotation: 0 }, grid: { color: palette.grid } },
                y: { ticks: { color: palette.text, precision: 0 }, grid: { color: palette.grid } },
              },
            },
          });
        }

        const activity = document.getElementById("chartActivity");
        if (activity) {
          new Chart(activity, {
            type: "line",
            data: {
              labels: data.activity.labels,
              datasets: [
                {
                  label: "Events scheduled",
                  data: data.activity.events,
                  borderColor: palette.primary,
                  backgroundColor: "rgba(45, 98, 255, 0.18)",
                  fill: true,
                  tension: 0.25,
                  pointRadius: 1,
                },
                {
                  label: "Matches created",
                  data: data.activity.matches,
                  borderColor: palette.accent,
                  backgroundColor: "rgba(255, 107, 53, 0.12)",
                  fill: true,
                  tension: 0.25,
                  pointRadius: 1,
                },
              ],
            },
            options: {
              ...baseOptions,
              interaction: { mode: "index", intersect: false },
              scales: {
                x: { ticks: { color: palette.text, maxRotation: 0 }, grid: { color: palette.grid } },
                y: { ticks: { color: palette.text, precision: 0 }, grid: { color: palette.grid } },
              },
            },
          });
        }
      })();
    </script>
  </body>
</html>
