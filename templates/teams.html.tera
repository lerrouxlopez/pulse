<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Teams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Teams</h1>
            <p class="text-cream-75 mb-0">Manage teams for {{ tournament_name }}.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Create Team</h3>
          <form action="/teams" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-3">
            <div class="d-flex flex-wrap gap-2">
              <input class="form-control flex-grow-1" name="name" placeholder="Team name" />
              <input class="form-control flex-grow-1" type="file" name="logo_file" accept="image/*" />
              <button class="btn btn-outline-light" type="submit">Add Team</button>
            </div>
            <div class="d-flex flex-wrap gap-4">
              <div>
                <p class="text-cream-60 mb-2">Divisions</p>
                {% for division in divisions %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="division_ids" value="{{ division.id }}" id="new-division-{{ division.id }}">
                  <label class="form-check-label" for="new-division-{{ division.id }}">{{ division.name }}</label>
                </div>
                {% endfor %}
              </div>
              <div>
                <p class="text-cream-60 mb-2">Categories</p>
                {% for category in categories %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="category_ids" value="{{ category.id }}" id="new-category-{{ category.id }}">
                  <label class="form-check-label" for="new-category-{{ category.id }}">{{ category.name }}</label>
                </div>
                {% endfor %}
              </div>
              <div>
                <p class="text-cream-60 mb-2">Events</p>
                {% for event in events %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="event_ids" value="{{ event.id }}" id="new-event-{{ event.id }}">
                  <label class="form-check-label" for="new-event-{{ event.id }}">{{ event.name }}</label>
                </div>
                {% endfor %}
              </div>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Teams</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Team</th>
                  <th scope="col">Members</th>
                  <th scope="col" class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for team in teams %}
                <tr>
                  <td>
                    <form action="/teams/{{ team.id }}/update" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-3">
                      <div class="d-flex gap-2">
                        <input class="form-control" name="name" value="{{ team.name }}" />
                        <input class="form-control" type="file" name="logo_file" accept="image/*" />
                        <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                      </div>
                      {% if team.logo_url %}
                      <img src="{{ team.logo_url }}" alt="Team logo" style="width: 52px; height: 52px; object-fit: cover; border-radius: 12px;">
                      {% endif %}
                      <div class="d-flex flex-wrap gap-4">
                        <div>
                          <p class="text-cream-60 mb-2">Divisions</p>
                          {% for division in divisions %}
                          <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="division_ids" value="{{ division.id }}" id="team-{{ team.id }}-division-{{ division.id }}"
                              {% if division.id in team.division_ids %}checked{% endif %}>
                            <label class="form-check-label" for="team-{{ team.id }}-division-{{ division.id }}">{{ division.name }}</label>
                          </div>
                          {% endfor %}
                        </div>
                        <div>
                          <p class="text-cream-60 mb-2">Categories</p>
                          {% for category in categories %}
                          <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="category_ids" value="{{ category.id }}" id="team-{{ team.id }}-category-{{ category.id }}"
                              {% if category.id in team.category_ids %}checked{% endif %}>
                            <label class="form-check-label" for="team-{{ team.id }}-category-{{ category.id }}">{{ category.name }}</label>
                          </div>
                          {% endfor %}
                        </div>
                        <div>
                          <p class="text-cream-60 mb-2">Events</p>
                          {% for event in events %}
                          <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="event_ids" value="{{ event.id }}" id="team-{{ team.id }}-event-{{ event.id }}"
                              {% if event.id in team.event_ids %}checked{% endif %}>
                            <label class="form-check-label" for="team-{{ team.id }}-event-{{ event.id }}">{{ event.name }}</label>
                          </div>
                          {% endfor %}
                        </div>
                      </div>
                    </form>
                  </td>
                  <td>
                    <div class="d-flex flex-column gap-2">
                      <form action="/teams/{{ team.id }}/members" method="post" class="d-flex gap-2">
                        <input class="form-control" name="name" placeholder="Add member" />
                        <button class="btn btn-sm btn-outline-light" type="submit">Add</button>
                      </form>
                    <div class="d-flex flex-wrap gap-2">
                      {% for member in team.members %}
                        <form action="/teams/members/{{ member.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-dark" type="submit">
                            {{ member.name }} x
                          </button>
                        </form>
                        {% else %}
                        <span class="text-cream-60">No members yet.</span>
                        {% endfor %}
                      </div>
                    </div>
                  </td>
                  <td class="text-end">
                    <form action="/teams/{{ team.id }}/delete" method="post">
                      <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="3" class="text-cream-60">No teams yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
