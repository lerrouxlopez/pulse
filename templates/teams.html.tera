<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Teams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Teams</h1>
            <p class="text-cream-75 mb-0">Manage teams for {{ tournament_name }}.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}
        {% if import_failures | length > 0 %}
        <div class="alert alert-warning">
          <div class="fw-semibold mb-2">Failed Rows (for correction)</div>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Row</th>
                  <th>Data</th>
                  <th>Error</th>
                </tr>
              </thead>
              <tbody>
                {% for failure in import_failures %}
                <tr>
                  <td>{{ failure.row_number }}</td>
                  <td><code>{{ failure.row_data }}</code></td>
                  <td>{{ failure.error }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
        {% endif %}

        <section class="panel mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <h3 class="fw-semibold mb-0">Import Teams / Members</h3>
              <span class="text-cream-60 small">CSV or XLSX with partial success handling</span>
            </div>
          </div>
          <form action="/{{ tournament_slug }}/teams/import" method="post" enctype="multipart/form-data" class="row g-3">
            <div class="col-md-3">
              <label class="form-label text-cream-60">Import Type</label>
              <select class="form-select" name="import_type">
                <option value="teams">Teams</option>
                <option value="members">Members</option>
              </select>
            </div>
            <div class="col-md-5">
              <label class="form-label text-cream-60">Upload File</label>
              <input class="form-control" type="file" name="import_file" accept=".csv,.xlsx" required />
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
              <button class="btn btn-outline-light" type="submit">Import</button>
              <a class="btn btn-outline-secondary" href="/{{ tournament_slug }}/teams/import/template/teams" download="teams-template.csv">Download Teams Template</a>
              <a class="btn btn-outline-secondary" href="/{{ tournament_slug }}/teams/import/template/members" download="members-template.csv">Download Members Template</a>
            </div>
          </form>
          <div class="mt-3 text-cream-60 small">
            For columns that accept multiple values (for example: <code>divisions</code>, <code>categories</code>, <code>events</code>), separate entries with a pipe <code>|</code>.
            Example: <code>Male Division|Female Division</code> or <code>Single Live Stick|Double Live Stick</code>.
          </div>
        </section>

        <section class="panel mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <h3 class="fw-semibold mb-0">Create Team</h3>
              <span class="text-cream-60 small">Standard setup</span>
            </div>
          </div>
          <div class="drawer-content" id="create-team-drawer">
            <form action="/{{ tournament_slug }}/teams" method="post" enctype="multipart/form-data">
              <div class="row g-3">
                <div class="col-lg-6">
                  <label class="form-label text-cream-60">Team Name</label>
                  <input class="form-control" name="name" placeholder="e.g. Dragon Dojo" />
                </div>
                <div class="col-lg-6">
                  <label class="form-label text-cream-60">Team Logo</label>
                  <input class="form-control" type="file" name="logo_file" accept="image/*" />
                </div>
              </div>

              <div class="row g-4 mt-1">
                <div class="col-md-4">
                  <p class="text-cream-60 mb-2">Gender Divisions</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="new-select-all-divisions" data-group="new-team-divisions" />
                    <label class="form-check-label" for="new-select-all-divisions">Select all</label>
                  </div>
                  {% for division in divisions %}
                  <div class="form-check">
                    <input class="form-check-input js-select-item" type="checkbox" name="division_ids" value="{{ division.id }}" id="new-division-{{ division.id }}" data-group="new-team-divisions">
                    <label class="form-check-label" for="new-division-{{ division.id }}">{{ division.name }}</label>
                  </div>
                  {% endfor %}
                </div>
                <div class="col-md-4">
                  <p class="text-cream-60 mb-2">Age Categories</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="new-select-all-categories" data-group="new-team-categories" />
                    <label class="form-check-label" for="new-select-all-categories">Select all</label>
                  </div>
                  {% for category in categories %}
                  <div class="form-check">
                    <input class="form-check-input js-select-item" type="checkbox" name="category_ids" value="{{ category.id }}" id="new-category-{{ category.id }}" data-group="new-team-categories">
                    <label class="form-check-label" for="new-category-{{ category.id }}">{{ category.name }}</label>
                  </div>
                  {% endfor %}
                </div>
                <div class="col-md-4">
                  <p class="text-cream-60 mb-2">Events</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="new-select-all-events" data-group="new-team-events" />
                    <label class="form-check-label" for="new-select-all-events">Select all</label>
                  </div>
                  {% for event in events %}
                  <div class="form-check">
                    <input class="form-check-input js-select-item" type="checkbox" name="event_ids" value="{{ event.id }}" id="new-event-{{ event.id }}" data-group="new-team-events">
                    <label class="form-check-label" for="new-event-{{ event.id }}">{{ event.name }}</label>
                  </div>
                  {% endfor %}
                </div>
              </div>
              <div class="d-flex justify-content-end mt-4">
                <button class="btn btn-outline-light" type="submit">Add Team</button>
              </div>
            </form>
          </div>
          <div class="drawer-handle">
            <button class="drawer-toggle-btn is-collapsed js-drawer-toggle" type="button" data-drawer-target="create-team-drawer" aria-expanded="false" aria-label="Toggle create team">
              <span class="drawer-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </span>
            </button>
          </div>
        </section>

        <section class="panel">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Teams</h3>
          </div>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0 teams-table">
              <thead>
                <tr>
                  <th scope="col" class="team-col">Team</th>
                  <th scope="col">Gender Divisions</th>
                  <th scope="col">Age Categories</th>
                  <th scope="col">Events</th>
                  <th scope="col" class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for team in teams %}
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      {% if team.logo_url %}
                      <img src="{{ team.logo_url }}" alt="Team logo" style="width: 40px; height: 40px; object-fit: cover; border-radius: 12px;">
                      {% else %}
                      <img src="/static/placeholders/team-1.svg" data-placeholder="team" data-seed="{{ team.id }}" alt="Team logo placeholder" style="width: 40px; height: 40px; object-fit: cover; border-radius: 12px;">
                      {% endif %}
                      <div>
                        <a class="fw-semibold text-decoration-none" href="/{{ tournament_slug }}/teams/{{ team.id }}">{{ team.name }}</a>
                        <div class="text-cream-60 small">{{ team.members | length }} players</div>
                        {% if team.logo_url %}
                        <a class="small text-decoration-none" href="{{ team.logo_url }}" target="_blank">View logo</a>
                        {% endif %}
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for division in team.divisions %}
                      <span class="badge text-bg-light text-ink">{{ division.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for category in team.categories %}
                      <span class="badge text-bg-light text-ink">{{ category.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for event in team.events %}
                      <span class="badge text-bg-light text-ink">{{ event.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editTeamModal-{{ team.id }}">
                        Edit
                      </button>
                      <form action="/{{ tournament_slug }}/teams/{{ team.id }}/delete" method="post">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="3" class="text-cream-60">No teams yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for team in teams %}
        <div class="modal fade" id="editTeamModal-{{ team.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Team</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/{{ tournament_slug }}/teams/{{ team.id }}/update" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-lg-6">
                      <label class="form-label text-muted">Team Name</label>
                      <input class="form-control" name="name" value="{{ team.name }}" />
                    </div>
                    <div class="col-lg-6">
                      <label class="form-label text-muted">Team Logo</label>
                      <input class="form-control" type="file" name="logo_file" accept="image/*" />
                    </div>
                  </div>

                  <div class="row g-4 mt-1">
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Divisions</p>
                      <div class="form-check mb-2">
                        <input class="form-check-input js-select-all" type="checkbox" id="edit-{{ team.id }}-select-all-divisions" data-group="edit-{{ team.id }}-divisions" />
                        <label class="form-check-label" for="edit-{{ team.id }}-select-all-divisions">Select all</label>
                      </div>
                      {% for division in divisions %}
                      <div class="form-check">
                        <input class="form-check-input js-select-item" type="checkbox" name="division_ids" value="{{ division.id }}" id="edit-{{ team.id }}-division-{{ division.id }}" data-group="edit-{{ team.id }}-divisions"
                          {% if division.id in team.division_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-division-{{ division.id }}">{{ division.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Categories</p>
                      <div class="form-check mb-2">
                        <input class="form-check-input js-select-all" type="checkbox" id="edit-{{ team.id }}-select-all-categories" data-group="edit-{{ team.id }}-categories" />
                        <label class="form-check-label" for="edit-{{ team.id }}-select-all-categories">Select all</label>
                      </div>
                      {% for category in categories %}
                      <div class="form-check">
                        <input class="form-check-input js-select-item" type="checkbox" name="category_ids" value="{{ category.id }}" id="edit-{{ team.id }}-category-{{ category.id }}" data-group="edit-{{ team.id }}-categories"
                          {% if category.id in team.category_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-category-{{ category.id }}">{{ category.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Events</p>
                      <div class="form-check mb-2">
                        <input class="form-check-input js-select-all" type="checkbox" id="edit-{{ team.id }}-select-all-events" data-group="edit-{{ team.id }}-events" />
                        <label class="form-check-label" for="edit-{{ team.id }}-select-all-events">Select all</label>
                      </div>
                      {% for event in events %}
                      <div class="form-check">
                        <input class="form-check-input js-select-item" type="checkbox" name="event_ids" value="{{ event.id }}" id="edit-{{ team.id }}-event-{{ event.id }}" data-group="edit-{{ team.id }}-events"
                          {% if event.id in team.event_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-event-{{ event.id }}">{{ event.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
    <script>
      (() => {
        const updateSelectAllState = (group) => {
          const selectAll = document.querySelector(`.js-select-all[data-group="${group}"]`);
          if (!selectAll) {
            return;
          }

          const items = Array.from(document.querySelectorAll(`.js-select-item[data-group="${group}"]`))
            .filter((item) => !item.disabled);

          const checkedCount = items.filter((item) => item.checked).length;
          const allChecked = items.length > 0 && checkedCount === items.length;
          const noneChecked = checkedCount === 0;

          selectAll.checked = allChecked;
          selectAll.indeterminate = !allChecked && !noneChecked;
        };

        document.querySelectorAll(".js-select-all").forEach((selectAll) => {
          const group = selectAll.dataset.group;
          selectAll.addEventListener("change", () => {
            document.querySelectorAll(`.js-select-item[data-group="${group}"]`).forEach((item) => {
              if (!item.disabled) {
                item.checked = selectAll.checked;
              }
            });
            updateSelectAllState(group);
          });
          updateSelectAllState(group);
        });

        document.querySelectorAll(".js-select-item").forEach((item) => {
          item.addEventListener("change", () => updateSelectAllState(item.dataset.group));
        });
      })();
    </script>
    <script>
      const drawerToggles = document.querySelectorAll(".js-drawer-toggle");
      drawerToggles.forEach((toggle) => {
        const targetId = toggle.dataset.drawerTarget;
        const drawer = document.getElementById(targetId);
        if (!drawer) {
          return;
        }
        const extraSpace = 12;
        if (drawer.classList.contains("is-open")) {
          drawer.style.maxHeight = `${drawer.scrollHeight + extraSpace}px`;
        } else {
          drawer.style.maxHeight = "0px";
        }
        toggle.addEventListener("click", () => {
          const isOpen = drawer.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(isOpen));
          toggle.classList.toggle("is-collapsed", !isOpen);
          if (isOpen) {
            drawer.style.maxHeight = `${drawer.scrollHeight + extraSpace}px`;
          } else {
            drawer.style.maxHeight = "0px";
          }
        });
        window.addEventListener("resize", () => {
          if (drawer.classList.contains("is-open")) {
            drawer.style.maxHeight = `${drawer.scrollHeight + extraSpace}px`;
          }
        });
      });
    </script>
    <script>
      const placeholderSets = {
        team: ["/static/placeholders/team-1.svg", "/static/placeholders/team-2.svg", "/static/placeholders/team-3.svg"],
        player: ["/static/placeholders/player-1.svg", "/static/placeholders/player-2.svg", "/static/placeholders/player-3.svg"]
      };

      const seededIndex = (seed, length) => {
        const value = String(seed || "");
        let hash = 0;
        for (let i = 0; i < value.length; i += 1) {
          hash = (hash * 31 + value.charCodeAt(i)) % 2147483647;
        }
        return length === 0 ? 0 : Math.abs(hash) % length;
      };

      document.querySelectorAll("img[data-placeholder]").forEach((img) => {
        const kind = img.dataset.placeholder;
        const options = placeholderSets[kind];
        if (!options || options.length === 0) {
          return;
        }
        const index = seededIndex(img.dataset.seed, options.length);
        img.src = options[index];
      });
    </script>
  </body>
</html>
