<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Teams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Teams</h1>
            <p class="text-cream-75 mb-0">Manage teams for {{ tournament_name }}.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Create Team</h3>
            <span class="text-cream-60 small">Standard setup</span>
          </div>
          <form action="/{{ tournament_slug }}/teams" method="post" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-lg-6">
                <label class="form-label text-cream-60">Team Name</label>
                <input class="form-control" name="name" placeholder="e.g. Dragon Dojo" />
              </div>
              <div class="col-lg-6">
                <label class="form-label text-cream-60">Team Logo</label>
                <input class="form-control" type="file" name="logo_file" accept="image/*" />
              </div>
            </div>

            <div class="row g-4 mt-1">
              <div class="col-md-4">
                <p class="text-cream-60 mb-2">Divisions</p>
                {% for division in divisions %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="division_ids" value="{{ division.id }}" id="new-division-{{ division.id }}">
                  <label class="form-check-label" for="new-division-{{ division.id }}">{{ division.name }}</label>
                </div>
                {% endfor %}
              </div>
              <div class="col-md-4">
                <p class="text-cream-60 mb-2">Categories</p>
                {% for category in categories %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="category_ids" value="{{ category.id }}" id="new-category-{{ category.id }}">
                  <label class="form-check-label" for="new-category-{{ category.id }}">{{ category.name }}</label>
                </div>
                {% endfor %}
              </div>
              <div class="col-md-4">
                <p class="text-cream-60 mb-2">Events</p>
                {% for event in events %}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="event_ids" value="{{ event.id }}" id="new-event-{{ event.id }}">
                  <label class="form-check-label" for="new-event-{{ event.id }}">{{ event.name }}</label>
                </div>
                {% endfor %}
              </div>
            </div>
            <div class="d-flex justify-content-end mt-4">
              <button class="btn btn-outline-light" type="submit">Add Team</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Teams</h3>
          </div>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Team</th>
                  <th scope="col">Divisions</th>
                  <th scope="col">Categories</th>
                  <th scope="col">Events</th>
                  <th scope="col" class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for team in teams %}
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      {% if team.logo_url %}
                      <img src="{{ team.logo_url }}" alt="Team logo" style="width: 40px; height: 40px; object-fit: cover; border-radius: 12px;">
                      {% else %}
                      <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-radius: 12px;">?</div>
                      {% endif %}
                      <div>
                        <a class="fw-semibold text-decoration-none" href="/{{ tournament_slug }}/teams/{{ team.id }}">{{ team.name }}</a>
                        <div class="text-cream-60 small">{{ team.members | length }} players</div>
                        {% if team.logo_url %}
                        <a class="small text-decoration-none" href="{{ team.logo_url }}" target="_blank">View logo</a>
                        {% endif %}
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for division in team.divisions %}
                      <span class="badge text-bg-light text-ink">{{ division.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for category in team.categories %}
                      <span class="badge text-bg-light text-ink">{{ category.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      {% for event in team.events %}
                      <span class="badge text-bg-light text-ink">{{ event.name }}</span>
                      {% else %}
                      <span class="text-cream-60 small">None</span>
                      {% endfor %}
                    </div>
                  </td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editTeamModal-{{ team.id }}">
                        Edit
                      </button>
                      <form action="/{{ tournament_slug }}/teams/{{ team.id }}/delete" method="post">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="3" class="text-cream-60">No teams yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for team in teams %}
        <div class="modal fade" id="editTeamModal-{{ team.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Team</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/{{ tournament_slug }}/teams/{{ team.id }}/update" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-lg-6">
                      <label class="form-label text-muted">Team Name</label>
                      <input class="form-control" name="name" value="{{ team.name }}" />
                    </div>
                    <div class="col-lg-6">
                      <label class="form-label text-muted">Team Logo</label>
                      <input class="form-control" type="file" name="logo_file" accept="image/*" />
                    </div>
                  </div>
                  <div class="mt-3">
                    <label class="form-label text-muted">Add Player</label>
                    <div class="row g-2">
                      <div class="col-md-6">
                        <input class="form-control" name="name" placeholder="Player name" />
                      </div>
                      <div class="col-md-4">
                        <input class="form-control" type="file" name="photo_file" accept="image/*" />
                      </div>
                      <div class="col-md-2 d-grid">
                        <button class="btn btn-outline-light" type="submit" formaction="/{{ tournament_slug }}/teams/{{ team.id }}/members">
                          Add
                        </button>
                      </div>
                    </div>
                  </div>
                  <div class="mt-3">
                    <label class="form-label text-muted">Players</label>
                    <div class="d-flex flex-column gap-2">
                      {% for member in team.members %}
                      <div class="d-flex align-items-center gap-2">
                        {% if member.photo_url %}
                        <img src="{{ member.photo_url }}" alt="Player photo" style="width: 36px; height: 36px; object-fit: cover; border-radius: 10px;">
                        {% else %}
                        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; border-radius: 10px;">?</div>
                        {% endif %}
                        <form action="/{{ tournament_slug }}/teams/members/{{ member.id }}/update" method="post" enctype="multipart/form-data" class="d-flex flex-grow-1 gap-2">
                          <input class="form-control form-control-sm" name="name" value="{{ member.name }}" />
                          <input class="form-control form-control-sm" type="file" name="photo_file" accept="image/*" />
                          <div class="form-check d-flex align-items-center gap-1">
                            <input class="form-check-input" type="checkbox" name="clear_photo" id="clear-photo-modal-{{ member.id }}">
                            <label class="form-check-label small" for="clear-photo-modal-{{ member.id }}">Clear</label>
                          </div>
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                        <form action="/{{ tournament_slug }}/teams/members/{{ member.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </div>
                      {% else %}
                      <span class="text-muted">No players yet.</span>
                      {% endfor %}
                    </div>
                  </div>

                  <div class="row g-4 mt-1">
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Divisions</p>
                      {% for division in divisions %}
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="division_ids" value="{{ division.id }}" id="edit-{{ team.id }}-division-{{ division.id }}"
                          {% if division.id in team.division_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-division-{{ division.id }}">{{ division.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Categories</p>
                      {% for category in categories %}
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="category_ids" value="{{ category.id }}" id="edit-{{ team.id }}-category-{{ category.id }}"
                          {% if category.id in team.category_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-category-{{ category.id }}">{{ category.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                    <div class="col-md-4">
                      <p class="text-muted mb-2">Events</p>
                      {% for event in events %}
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="event_ids" value="{{ event.id }}" id="edit-{{ team.id }}-event-{{ event.id }}"
                          {% if event.id in team.event_ids %}checked{% endif %}>
                        <label class="form-check-label" for="edit-{{ team.id }}-event-{{ event.id }}">{{ event.name }}</label>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
