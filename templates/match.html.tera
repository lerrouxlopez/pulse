<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Match</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body match-page sidebar-collapsed" data-sidebar-initial="collapsed">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Expand sidebar" aria-expanded="false">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Match</h1>
            <p class="text-cream-75 mb-0">Live match view for {{ tournament_name }}.</p>
          </div>
          <a class="btn btn-outline-light" href="/{{ tournament_slug }}/matches">Back to Matches</a>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}

        <section class="match-live-shell">
          <div class="match-live-head">
            <span id="js-live-status" class="pill {{ match_item.status_class }}">{{ match_item.status }}</span>
            <h2 class="match-live-title">{{ match_item.event_name }}</h2>
            <p class="match-live-meta mb-0">
              {% if match_item.division_name %}{{ match_item.division_name }}{% endif %}
              {% if match_item.division_name and match_item.weight_class_name %} - {% endif %}
              {% if match_item.weight_class_name %}{{ match_item.weight_class_name }}{% endif %}
            </p>
          </div>

          <div class="match-live-stage">
            <div class="match-live-fighter is-red">
              <div class="match-live-photo-frame">
                <img src="{{ match_item.red_photo_url }}" alt="{{ match_item.red_name }}" class="match-live-photo" />
              </div>
              <div class="match-live-name">{{ match_item.red_name }}</div>
              <div class="pill match-card-pill">Total: <span id="js-live-red-total">{{ match_item.red_total_score }}</span></div>
            </div>

            <div class="match-live-center">
              <div class="match-live-vs">VS</div>
              <div id="js-live-round" class="match-live-round">{{ match_item.round_label }}</div>
              <div
                id="js-live-timer"
                class="match-live-timer"
                data-timer-started-at="{{ match_item.timer_started_at | default(value=0) }}"
                data-timer-duration="{{ match_item.timer_duration_seconds | default(value=0) }}"
                data-timer-running="{% if match_item.timer_is_running %}1{% else %}0{% endif %}"
                aria-label="Match timer"
              >
                --:--
              </div>

              {% if can_control_timer %}
              {% set is_running = match_item.timer_is_running or match_item.status == "Ongoing" %}
              {% set last_completed = match_item.timer_last_completed_round | default(value=0) %}
              {% set selected_round = match_item.fight_round | default(value=1) %}
              <div class="match-live-controls" aria-label="Match timer controls">
                {% if match_item.status == "Ongoing" %}
                <form action="/{{ tournament_slug }}/matches/{{ match_item.id }}/toggle-pause" method="post" class="match-live-controls-form">
                  <button class="btn btn-sm btn-outline-light" type="submit" aria-label="{% if match_item.timer_is_running %}Pause timer{% else %}Resume timer{% endif %}">
                    {% if match_item.timer_is_running %}
                    <span class="match-live-controls-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="16" height="16">
                        <path d="M8 5v14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        <path d="M16 5v14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                      </svg>
                    </span>
                    Pause
                    {% else %}
                    <span class="match-live-controls-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="16" height="16">
                        <path d="M8 5l11 7-11 7z" fill="currentColor"></path>
                      </svg>
                    </span>
                    Resume
                    {% endif %}
                  </button>
                </form>
                {% endif %}

                <form action="/{{ tournament_slug }}/matches/{{ match_item.id }}/toggle-timer" method="post" class="match-live-controls-form match-live-timer-form">
                  <button class="btn btn-sm {% if is_running %}btn-outline-warning{% else %}btn-outline-success{% endif %}" type="submit" {% if not is_running and selected_round <= last_completed %}disabled{% endif %}>
                    {% if is_running %}Stop{% else %}Start{% endif %}
                  </button>
                  <select class="form-select form-select-sm" name="fight_round" {% if is_running %}disabled{% endif %} aria-label="Select round">
                    {% for option in fight_round_options %}
                    <option value="{{ option }}" title="Round {{ option }}" {% if option == selected_round %}selected{% endif %}>R{{ option }}</option>
                    {% endfor %}
                  </select>
                </form>
              </div>
              {% endif %}
            </div>

            <div class="match-live-fighter is-blue">
              <div class="match-live-photo-frame">
                <img src="{{ match_item.blue_photo_url }}" alt="{{ match_item.blue_name }}" class="match-live-photo" />
              </div>
              <div class="match-live-name">{{ match_item.blue_name }}</div>
              <div class="pill match-card-pill">Total: <span id="js-live-blue-total">{{ match_item.blue_total_score }}</span></div>
            </div>
          </div>

          <div id="js-live-judges" class="match-live-judges"></div>
        </section>
      </main>
    </div>
    <script src="/static/sidebar.js"></script>
    <script>
      const statusEl = document.getElementById("js-live-status");
      const roundEl = document.getElementById("js-live-round");
      const redTotalEl = document.getElementById("js-live-red-total");
      const blueTotalEl = document.getElementById("js-live-blue-total");
      const timerEl = document.getElementById("js-live-timer");
      const judgesEl = document.getElementById("js-live-judges");

      const pad2 = (value) => String(Math.max(0, value)).padStart(2, "0");
      const formatTimer = (seconds) => {
        const minutes = Math.floor(seconds / 60);
        const secs = seconds % 60;
        return `${pad2(minutes)}:${pad2(secs)}`;
      };
      const statusClass = (status) => {
        const normalized = String(status || "").toLowerCase();
        if (normalized === "finished") return "status-ok";
        if (normalized === "ongoing") return "status-live";
        return "status-ready";
      };
      const renderTimer = () => {
        if (!timerEl) return;
        const startedAt = Number(timerEl.dataset.timerStartedAt || "0");
        const duration = Number(timerEl.dataset.timerDuration || "0");
        const isRunning = timerEl.dataset.timerRunning === "1";
        if (!startedAt || !duration) {
          timerEl.textContent = "00:00";
          timerEl.classList.remove("is-expired");
          return;
        }

        const now = Math.floor(Date.now() / 1000);
        const elapsed = Math.max(0, now - startedAt);
        const shown = Math.max(0, Math.min(duration, elapsed));
        timerEl.textContent = formatTimer(shown);
        timerEl.classList.toggle("is-expired", elapsed >= duration);
      };

      const renderJudges = (judges, isVoteMode) => {
        if (!judgesEl) return;
        judgesEl.innerHTML = (judges || [])
          .map((judge) => {
            const safeName = String(judge.name || "");
            const safePhoto = String(judge.photo_url || "");
            const red = Number(judge.red_score || 0);
            const blue = Number(judge.blue_score || 0);
            const voteRaw = String(judge.vote_side || "").toLowerCase();
            const voteLabel =
              voteRaw === "red" ? "RED" : voteRaw === "blue" ? "BLUE" : "—";
            const voteClass =
              voteRaw === "red" ? "is-red" : voteRaw === "blue" ? "is-blue" : "is-none";
            return `
              <article class="judge-card">
                <div class="judge-left">
                  <div class="judge-photo-frame">
                    <img src="${safePhoto}" alt="${safeName}" class="judge-photo" />
                  </div>
                  <div class="judge-meta">
                    <h3 class="judge-name">${safeName}</h3>
                  </div>
                </div>
                <div class="judge-right">
                  <div class="judge-score-label">${isVoteMode ? "Vote" : "Score"}</div>
                  ${
                    isVoteMode
                      ? `<div class="judge-score"><span class="judge-vote-pill ${voteClass}">${voteLabel}</span></div>`
                      : `<div class="judge-score">Red: ${red} | Blue: ${blue}</div>`
                  }
                </div>
              </article>
            `;
          })
          .join("");
      };

      const pollUrl = `/{{ tournament_slug }}/matches/{{ match_item.id }}/live`;
      let inFlight = false;
      const poll = async () => {
        if (inFlight) return;
        inFlight = true;
        try {
          const res = await fetch(pollUrl, { credentials: "same-origin" });
          if (!res.ok) return;
          const data = await res.json();
          if (statusEl) {
            statusEl.textContent = data.status || "";
            statusEl.classList.remove("status-ok", "status-live", "status-ready");
            statusEl.classList.add(statusClass(data.status));
          }
          if (roundEl) {
            roundEl.textContent = data.round_label || "";
          }
          if (redTotalEl) redTotalEl.textContent = String(data.red_total_score ?? 0);
          if (blueTotalEl) blueTotalEl.textContent = String(data.blue_total_score ?? 0);
          if (timerEl) {
            timerEl.dataset.timerStartedAt = String(data.timer_started_at ?? 0);
            timerEl.dataset.timerDuration = String(data.timer_duration_seconds ?? 0);
            timerEl.dataset.timerRunning = data.timer_is_running ? "1" : "0";
            renderTimer();
          }
          renderJudges(data.judges, !!data.is_pause_vote_scoring);
        } catch (_) {
          // ignore
        } finally {
          inFlight = false;
        }
      };

      renderJudges([], false);
      renderTimer();
      poll();
      setInterval(poll, 1000);
      setInterval(renderTimer, 250);
    </script>
  </body>
</html>
