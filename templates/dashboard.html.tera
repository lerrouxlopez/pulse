<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex align-items-center justify-content-between mb-4">
          <div>
            <h1 class="fw-bold mb-1">Tournament Dashboard</h1>
            <p class="text-cream-75 mb-0">
              Welcome back, {{ name }}.{% if current_tournament_name %} Currently viewing {{ current_tournament_name }}.{% endif %}
            </p>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge text-bg-light text-ink">Day 1 • 6 Mats • Live</span>
            <form action="/tournaments/new" method="post">
              <input type="hidden" name="name" value="New Tournament" />
              <button class="btn btn-outline-light btn-sm" type="submit">Create New Tournament</button>
            </form>
          </div>
        </header>

        <section class="row g-3 mb-4">
          <div class="col-md-4">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Matches Today</p>
              <div class="d-flex align-items-end gap-3">
                <h2 class="mb-0 fw-bold">42</h2>
                <span class="pill status-ok">On Time</span>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Live Matches</p>
              <div class="d-flex align-items-end gap-3">
                <h2 class="mb-0 fw-bold">3</h2>
                <span class="pill status-live">Live</span>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <p class="text-cream-60 mb-2">Mats Active</p>
              <div class="d-flex align-items-end gap-3">
                <h2 class="mb-0 fw-bold">6</h2>
                <span class="pill status-ready">Full</span>
              </div>
            </div>
          </div>
        </section>

        <section class="panel mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Live & Upcoming Matches</h3>
            <button class="btn btn-outline-light btn-sm">View all</button>
          </div>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Mat</th>
                  <th scope="col">Category</th>
                  <th scope="col">Red</th>
                  <th scope="col">Blue</th>
                  <th scope="col">Status</th>
                </tr>
              </thead>
              <tbody>
                {% for row in matches %}
                <tr>
                  <td>{{ row.mat }}</td>
                  <td>{{ row.category }}</td>
                  <td>{{ row.red }}</td>
                  <td>{{ row.blue }}</td>
                  <td>
                    <span class="pill {{ row.status_class }}">{{ row.status }}</span>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel mb-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Event Outcomes</h3>
          </div>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Event</th>
                  <th scope="col">Division</th>
                  <th scope="col">Weight Class</th>
                  <th scope="col">Winner</th>
                  <th scope="col">Status</th>
                </tr>
              </thead>
              <tbody>
                {% for item in outcomes %}
                <tr>
                  <td>{{ item.event_name }}</td>
                  <td>{{ item.division_name | default(value="") }}</td>
                  <td>{{ item.weight_class_label | default(value="") }}</td>
                  <td>{{ item.winner_name | default(value="") }}</td>
                  <td>
                    <span class="pill status-ok">{{ item.status }}</span>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="5" class="text-cream-60">No outcomes yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel">
          <h4 class="fw-semibold mb-3">Quick Actions</h4>
          <div class="d-flex flex-wrap gap-3">
            <button class="btn btn-primary shadow-glow">Start Next Match</button>
            <button class="btn btn-outline-light">View Brackets</button>
            <button class="btn btn-outline-light">Assign Judges</button>
          </div>
        </section>
      </main>
    </div>

    {% if show_tournament_modal %}
    <div class="modal fade show" id="tournamentModal" tabindex="-1" aria-hidden="true" style="display: block;">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Select a Tournament</h5>
          </div>
          <div class="modal-body">
            <p class="text-muted">Choose an existing tournament or create a new one to continue.</p>
            <div class="table-responsive mb-4">
              <table class="table table-striped align-middle mb-0">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {% for tournament in tournaments %}
                  <tr>
                    <td>{{ tournament.name }}</td>
                    <td>
                      {% if tournament.started_at %}
                        Started
                      {% elif tournament.is_setup %}
                        Ready to start
                      {% else %}
                        Setup required
                      {% endif %}
                    </td>
                    <td class="text-end">
                      <a class="btn btn-outline-dark btn-sm" href="/{{ tournament.slug }}/dashboard">Open</a>
                    </td>
                  </tr>
                  {% else %}
                  <tr>
                    <td colspan="3" class="text-muted">No tournaments yet.</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            <form action="/tournaments/new" method="post" class="d-flex flex-wrap gap-2">
              <input class="form-control flex-grow-1" name="name" placeholder="New tournament name" />
              <button class="btn btn-primary" type="submit">Create Tournament</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-backdrop fade show"></div>
    {% endif %}

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
