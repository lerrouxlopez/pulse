<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Matches</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Matches</h1>
            <p class="text-cream-75 mb-0">Current matchups for {{ tournament_name }}.</p>
          </div>
        </header>

        <section class="matches-grid">
          {% for item in matches %}
          <article class="match-card panel">
            <div class="match-card-top">
              <div>
                <a class="match-card-link" href="/{{ tournament_slug }}/matches/{{ item.id }}">{{ item.event_name }}</a>
                <div class="d-flex flex-wrap gap-2">
                  {% if item.division_name %}
                  <span class="pill match-card-pill">{{ item.division_name }}</span>
                  {% endif %}
                  {% if item.weight_class_name %}
                  <span class="pill match-card-pill">{{ item.weight_class_name }}</span>
                  {% endif %}
                  <span class="pill match-card-pill">{{ item.event_type }}</span>
                </div>
              </div>
              <span class="pill {{ item.status_class }}">{{ item.status }}</span>
            </div>

            <div class="match-faceoff">
              <div class="match-fighter">
                <img src="{{ item.red_photo_url }}" alt="{{ item.red_name }}" class="match-fighter-photo" />
                <span class="match-fighter-name">{{ item.red_name }}</span>
              </div>
              <span class="match-vs">VS</span>
              <div class="match-fighter">
                <img src="{{ item.blue_photo_url }}" alt="{{ item.blue_name }}" class="match-fighter-photo" />
                <span class="match-fighter-name">{{ item.blue_name }}</span>
              </div>
            </div>
          </article>
          {% else %}
          <article class="panel">
            <p class="text-cream-60 mb-0">No matches available yet.</p>
          </article>
          {% endfor %}
        </section>
      </main>
    </div>
    <script src="/static/sidebar.js"></script>
  </body>
</html>
