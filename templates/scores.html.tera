<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Scores</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Scores</h1>
            <p class="text-cream-75 mb-0">Judge scoring console for {{ tournament_name }}.</p>
          </div>
        </header>

        <section class="panel mb-4 text-ink">
          <form method="get" action="/{{ tournament_slug }}/scores" class="row g-3 align-items-end">
            <div class="col-12 col-lg-6">
              <label class="form-label">Event</label>
              <select class="form-select" name="event_id" required>
                <option value="" {% if not selected_event_id %}selected{% endif %} disabled>Select an event</option>
                {% for item in event_options %}
                <option value="{{ item.id }}" {% if selected_event_id and item.id == selected_event_id %}selected{% endif %}>{{ item.name }}</option>
                {% endfor %}
              </select>
            </div>

            {% if selected_event_id %}
            <div class="col-12 col-lg-6">
              <label class="form-label">Division</label>
              <select class="form-select" name="division_id" required>
                <option value="" {% if not selected_division_id %}selected{% endif %} disabled>Select a division</option>
                {% for item in division_options %}
                <option value="{{ item.id }}" {% if selected_division_id and item.id == selected_division_id %}selected{% endif %}>{{ item.name }}</option>
                {% endfor %}
              </select>
            </div>
            {% endif %}

            {% if selected_event_id and selected_division_id %}
            <div class="col-12 col-lg-6">
              <label class="form-label">Weight</label>
              <select class="form-select" name="weight_class_id" required>
                <option value="" {% if not selected_weight_class_id %}selected{% endif %} disabled>Select a weight</option>
                {% for item in weight_options %}
                <option value="{{ item.id }}" {% if selected_weight_class_id and item.id == selected_weight_class_id %}selected{% endif %}>{{ item.name }}</option>
                {% endfor %}
              </select>
            </div>
            {% endif %}

            {% if selected_event_id and selected_division_id and selected_weight_class_id %}
            <div class="col-12 col-lg-6">
              <label class="form-label">Match</label>
              <select class="form-select" name="match_id" {% if not matches or matches | length == 0 %}disabled{% endif %} required>
                {% if matches and matches | length > 0 %}
                  <option value="" {% if not selected_match_id %}selected{% endif %} disabled>Select a match</option>
                  {% for item in matches %}
                  <option value="{{ item.id }}" {% if selected_match_id and item.id == selected_match_id %}selected{% endif %}>{{ item.label }} ({{ item.status }})</option>
                  {% endfor %}
                {% else %}
                  <option value="" selected>No matches ready for scoring.</option>
                {% endif %}
              </select>
            </div>

            {% if can_admin %}
            <div class="col-12 col-lg-3">
              <label class="form-label">Judge</label>
              <select class="form-select" name="judge_id" {% if not selected_match_id %}disabled{% endif %} required>
                {% for judge in judges %}
                <option value="{{ judge.id }}" {% if judge.id == selected_judge_id %}selected{% endif %}>{{ judge.name }}</option>
                {% endfor %}
              </select>
            </div>
            {% endif %}

            <div class="col-12 col-lg-3">
              <label class="form-label">Round</label>
              <select class="form-select" name="round" {% if not selected_match_id %}disabled{% endif %} required>
                {% for r in rounds %}
                <option value="{{ r }}" {% if r == selected_round %}selected{% endif %}>Round {{ r }}</option>
                {% endfor %}
              </select>
            </div>
            {% endif %}

            <div class="col-12 col-lg-3 d-flex justify-content-end gap-2">
              <a class="btn btn-outline-secondary w-100" href="/{{ tournament_slug }}/scores">Reset</a>
              <button class="btn btn-outline-light w-100" type="submit">Load</button>
            </div>
          </form>

          {% if selected_event_id and selected_division_id and selected_weight_class_id and matches is defined and (not matches or matches | length == 0) %}
            <div class="text-muted small mt-3">Only matches that are not finished and have assigned judges are shown here.</div>
          {% endif %}
        </section>

        {% set red_name = "TBD" %}
        {% set blue_name = "TBD" %}
        {% set red_photo_url = "/static/placeholders/player-1.svg" %}
        {% set blue_photo_url = "/static/placeholders/player-2.svg" %}
        {% if selected_match_detail %}
          {% set red_name = selected_match_detail.red_name %}
          {% set blue_name = selected_match_detail.blue_name %}
          {% set red_photo_url = selected_match_detail.red_photo_url %}
          {% set blue_photo_url = selected_match_detail.blue_photo_url %}
        {% endif %}

        {% if is_pause_vote_scoring %}
        <section class="panel mb-4 text-ink">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <h3 class="fw-semibold mb-0">Pause Vote</h3>
            {% if pending_pause_vote %}
            <div class="text-muted small">
              Round {{ pending_pause_vote.fight_round }} · Vote #{{ pending_pause_vote.pause_seq }} ·
              {{ pending_pause_vote.votes_cast }}/{{ pending_pause_vote.judge_count }} votes
            </div>
            {% endif %}
          </div>

          {% if pending_pause_vote %}
            <div class="mt-3">
              {% if pending_pause_vote.my_vote %}
              <div class="text-muted small mb-2">Your vote: <span class="fw-semibold">{{ pending_pause_vote.my_vote | upper }}</span></div>
              {% else %}
              <div class="text-muted small mb-2">Select which side earns 1 point for this pause.</div>
              {% endif %}

              <div class="d-flex flex-wrap gap-2">
                <form action="/{{ tournament_slug }}/scores/pause-vote" method="post">
                  {% if selected_event_id %}<input type="hidden" name="event_id" value="{{ selected_event_id }}" />{% endif %}
                  {% if selected_division_id %}<input type="hidden" name="division_id" value="{{ selected_division_id }}" />{% endif %}
                  {% if selected_weight_class_id %}<input type="hidden" name="weight_class_id" value="{{ selected_weight_class_id }}" />{% endif %}
                  <input type="hidden" name="match_id" value="{{ selected_match_id | default(value=0) }}" />
                  <input type="hidden" name="side" value="red" />
                  {% if can_admin %}
                  <input type="hidden" name="judge_user_id" value="{{ selected_judge_id }}" />
                  {% endif %}
                  <button class="btn btn-outline-danger" type="submit">Vote Red</button>
                </form>

                <form action="/{{ tournament_slug }}/scores/pause-vote" method="post">
                  {% if selected_event_id %}<input type="hidden" name="event_id" value="{{ selected_event_id }}" />{% endif %}
                  {% if selected_division_id %}<input type="hidden" name="division_id" value="{{ selected_division_id }}" />{% endif %}
                  {% if selected_weight_class_id %}<input type="hidden" name="weight_class_id" value="{{ selected_weight_class_id }}" />{% endif %}
                  <input type="hidden" name="match_id" value="{{ selected_match_id | default(value=0) }}" />
                  <input type="hidden" name="side" value="blue" />
                  {% if can_admin %}
                  <input type="hidden" name="judge_user_id" value="{{ selected_judge_id }}" />
                  {% endif %}
                  <button class="btn btn-outline-primary" type="submit">Vote Blue</button>
                </form>
              </div>

              {% if pending_pause_vote.is_complete %}
              <div class="text-muted small mt-2">All votes are in. The match can be resumed.</div>
              {% else %}
              <div class="text-muted small mt-2">Match cannot resume until all assigned judges vote.</div>
              {% endif %}
            </div>
          {% else %}
            <div class="text-muted mt-2">No pending vote. Voting opens when the match timer is paused.</div>
          {% endif %}
        </section>
        {% endif %}

        {% if not is_pause_vote_scoring %}
        <section class="panel text-ink">
          {% if is_non_contact_performance %}
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
              <img src="{{ red_photo_url }}" alt="{{ red_name }}" class="match-fighter-photo score-corner-photo" />
              <div class="min-w-0">
                <h3 class="fw-semibold mb-0">Performance</h3>
                <div class="text-secondary text-truncate">{{ red_name }}</div>
              </div>
            </div>
            <form action="/{{ tournament_slug }}/scores/adjust" method="post" class="d-flex align-items-center gap-2 flex-wrap">
              {% if selected_event_id %}<input type="hidden" name="event_id" value="{{ selected_event_id }}" />{% endif %}
              {% if selected_division_id %}<input type="hidden" name="division_id" value="{{ selected_division_id }}" />{% endif %}
              {% if selected_weight_class_id %}<input type="hidden" name="weight_class_id" value="{{ selected_weight_class_id }}" />{% endif %}
              <input type="hidden" name="match_id" value="{{ selected_match_id | default(value=0) }}" />
              <input type="hidden" name="fight_round" value="{{ selected_round }}" />
              <input type="hidden" name="side" value="red" />
              {% if can_admin %}
              <input type="hidden" name="judge_user_id" value="{{ selected_judge_id }}" />
              {% endif %}
              <select class="form-select w-auto" name="value" aria-label="Performance score">
                {% for value in allowed_scores %}
                <option value="{{ value }}" {% if value == red_score %}selected{% endif %}>{{ value }}</option>
                {% endfor %}
              </select>
              <button class="btn btn-outline-light" type="submit">Set</button>
            </form>
          </div>
          {% else %}
          <div class="row g-4">
            <div class="col-12 col-lg-6">
              <div class="d-flex align-items-center gap-3 mb-3">
                <img src="{{ red_photo_url }}" alt="{{ red_name }}" class="match-fighter-photo score-corner-photo" />
                <div class="min-w-0">
                  <h3 class="fw-semibold mb-0">Red</h3>
                  <div class="text-secondary text-truncate">{{ red_name }}</div>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/scores/adjust" method="post" class="d-flex align-items-center gap-2 flex-wrap">
                {% if selected_event_id %}<input type="hidden" name="event_id" value="{{ selected_event_id }}" />{% endif %}
                {% if selected_division_id %}<input type="hidden" name="division_id" value="{{ selected_division_id }}" />{% endif %}
                {% if selected_weight_class_id %}<input type="hidden" name="weight_class_id" value="{{ selected_weight_class_id }}" />{% endif %}
                <input type="hidden" name="match_id" value="{{ selected_match_id | default(value=0) }}" />
                <input type="hidden" name="fight_round" value="{{ selected_round }}" />
                <input type="hidden" name="side" value="red" />
                {% if can_admin %}
                <input type="hidden" name="judge_user_id" value="{{ selected_judge_id }}" />
                {% endif %}
                <select class="form-select w-auto" name="value" aria-label="Red score">
                  {% for value in allowed_scores %}
                  <option value="{{ value }}" {% if value == red_score %}selected{% endif %}>{{ value }}</option>
                  {% endfor %}
                </select>
                <button class="btn btn-outline-light" type="submit">Set</button>
              </form>
            </div>

            <div class="col-12 col-lg-6">
              <div class="d-flex align-items-center gap-3 mb-3 justify-content-lg-end">
                <div class="min-w-0 text-lg-end">
                  <h3 class="fw-semibold mb-0">Blue</h3>
                  <div class="text-secondary text-truncate">{{ blue_name }}</div>
                </div>
                <img src="{{ blue_photo_url }}" alt="{{ blue_name }}" class="match-fighter-photo score-corner-photo" />
              </div>
              <form action="/{{ tournament_slug }}/scores/adjust" method="post" class="d-flex align-items-center gap-2 flex-wrap justify-content-lg-end">
                {% if selected_event_id %}<input type="hidden" name="event_id" value="{{ selected_event_id }}" />{% endif %}
                {% if selected_division_id %}<input type="hidden" name="division_id" value="{{ selected_division_id }}" />{% endif %}
                {% if selected_weight_class_id %}<input type="hidden" name="weight_class_id" value="{{ selected_weight_class_id }}" />{% endif %}
                <input type="hidden" name="match_id" value="{{ selected_match_id | default(value=0) }}" />
                <input type="hidden" name="fight_round" value="{{ selected_round }}" />
                <input type="hidden" name="side" value="blue" />
                {% if can_admin %}
                <input type="hidden" name="judge_user_id" value="{{ selected_judge_id }}" />
                {% endif %}
                <select class="form-select w-auto" name="value" aria-label="Blue score">
                  {% for value in allowed_scores %}
                  <option value="{{ value }}" {% if value == blue_score %}selected{% endif %}>{{ value }}</option>
                  {% endfor %}
                </select>
                <button class="btn btn-outline-light" type="submit">Set</button>
              </form>
            </div>
          </div>
          {% endif %}
        </section>
        {% endif %}

        {% if not is_pause_vote_scoring %}
        <section class="panel mt-4 text-ink">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h3 class="fw-semibold mb-0">Round Scores</h3>
            <div class="text-muted small">Scores per round by assigned judges.</div>
          </div>

          {% if round_tables and round_tables | length > 0 %}
            {% for rt in round_tables %}
            <div class="{% if not loop.first %}mt-4{% endif %}">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                <div class="fw-semibold">Round {{ rt.round }}</div>
                <div class="text-muted small">
                  {% if is_non_contact_performance %}
                  Total: <span class="fw-semibold">{{ rt.red_total }}</span>
                  {% else %}
                  Totals: <span class="fw-semibold">{{ rt.red_total }}</span> - <span class="fw-semibold">{{ rt.blue_total }}</span>
                  {% endif %}
                </div>
              </div>
              <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col" style="width: 64px">#</th>
                      <th scope="col">Judge</th>
                      {% if is_non_contact_performance %}
                      <th scope="col" class="text-end">Score</th>
                      {% else %}
                      <th scope="col" class="text-end">Red</th>
                      <th scope="col" class="text-end">Blue</th>
                      {% endif %}
                    </tr>
                  </thead>
                  <tbody>
                    {% for j in rt.judges %}
                    <tr>
                      <td class="text-muted">{{ j.judge_order }}</td>
                      <td>{{ j.judge_name }}</td>
                      {% if is_non_contact_performance %}
                      <td class="text-end fw-semibold">{{ j.red_score }}</td>
                      {% else %}
                      <td class="text-end fw-semibold">{{ j.red_score }}</td>
                      <td class="text-end fw-semibold">{{ j.blue_score }}</td>
                      {% endif %}
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="{% if is_non_contact_performance %}3{% else %}4{% endif %}" class="text-muted">No judges assigned.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
            {% endfor %}
          {% else %}
            <div class="text-muted">Load a match to see round-by-round judge scores.</div>
          {% endif %}
        </section>
        {% endif %}
      </main>
    </div>
    <script src="/static/sidebar.js"></script>
  </body>
</html>
