<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/admin_sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Events</h1>
            <p class="text-cream-75 mb-0">Manage scheduled events across tournaments.</p>
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success" role="alert">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <div class="d-flex flex-wrap align-items-end justify-content-between gap-3">
            <div>
              <h3 class="fw-semibold mb-2">Tournament</h3>
              <form method="get" action="/admin/events" class="d-flex flex-wrap gap-2 align-items-center">
                <select class="form-select" name="tournament_id" onchange="this.form.submit()">
                  {% for t in tournaments %}
                  <option value="{{ t.id }}" {% if selected_tournament_id and t.id == selected_tournament_id %}selected{% endif %}>
                    {{ t.name }} ({{ t.slug }})
                  </option>
                  {% endfor %}
                </select>
                <noscript><button class="btn btn-outline-light" type="submit">Load</button></noscript>
              </form>
            </div>
            <a class="btn btn-outline-light" href="/admin/settings">Edit Settings</a>
          </div>
        </section>

        {% if not selected_tournament_id %}
          <div class="text-cream-60">No tournaments available.</div>
        {% else %}
        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Create Scheduled Event</h3>
          <form action="/admin/events/create" method="post" class="row g-3">
            <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
            <div class="col-md-4">
              <label class="form-label text-cream-60">Event</label>
              <select class="form-select" name="event_id" required>
                {% for e in events %}
                <option value="{{ e.id }}">{{ e.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label text-cream-60">Contact Type</label>
              <select class="form-select" name="contact_type" required>
                <option value="Contact">Contact</option>
                <option value="Non-Contact">Non-Contact</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label text-cream-60">Status</label>
              <select class="form-select" name="status" required>
                <option value="Scheduled">Scheduled</option>
                <option value="Ongoing">Ongoing</option>
                <option value="Finished">Finished</option>
                <option value="Cancelled">Cancelled</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Location (optional)</label>
              <input class="form-control" name="location" />
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Event Time (optional)</label>
              <input class="form-control" name="event_time" />
            </div>

            <div class="col-md-4">
              <label class="form-label text-cream-60">Point System (Contact only)</label>
              <select class="form-select" name="point_system">
                <option value="">(auto)</option>
                <option value="5-10 points">5-10 points</option>
                <option value="Must 8/10 points">Must 8/10 points</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label text-cream-60">Time Rule</label>
              <select class="form-select" name="time_rule">
                <option value="">(default)</option>
                <option value="1 round | 1 minute">1 round | 1 minute</option>
                <option value="1 round | 2 minutes">1 round | 2 minutes</option>
                <option value="3 rounds | 1 minute">3 rounds | 1 minute</option>
                <option value="No time limit">No time limit</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label text-cream-60">Draw System (Contact only)</label>
              <select class="form-select" name="draw_system">
                <option value="">(none)</option>
                <option value="Extension">Extension</option>
                <option value="First point Advantage">First point Advantage</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label text-cream-60">Gender Division</label>
              <select class="form-select" name="division_id" required>
                <option value="">(none)</option>
                {% for d in divisions %}
                <option value="{{ d.id }}">{{ d.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label text-cream-60">Weight Class</label>
              <select class="form-select" name="weight_class_id" required>
                <option value="">(none)</option>
                {% for w in weight_classes %}
                <option value="{{ w.id }}">{{ w.name }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="col-12 d-flex justify-content-end">
              <button class="btn btn-outline-light" type="submit">Create</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Scheduled Events</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 80px">ID</th>
                  <th>Event</th>
                  <th style="width: 120px">Type</th>
                  <th style="width: 120px">Status</th>
                  <th>Division</th>
                  <th>Weight</th>
                  <th style="width: 160px">Time Rule</th>
                  <th class="text-end" style="width: 280px">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for se in scheduled_events %}
                <tr>
                  <td class="text-cream-60">#{{ se.id }}</td>
                  <td class="fw-semibold">{{ se.event_name }}</td>
                  <td>{{ se.contact_type }}</td>
                  <td>{{ se.status }}</td>
                  <td>{{ se.division_name | default(value="") }}</td>
                  <td>{{ se.weight_class_name | default(value="") }}</td>
                  <td>{{ se.time_rule | default(value="") }}</td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editEventModal-{{ se.id }}">Edit</button>
                      <form action="/admin/events/{{ selected_tournament_id }}/{{ se.id }}/delete" method="post" onsubmit="return confirm('Delete this scheduled event?');">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="8" class="text-cream-60">No scheduled events.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        {% for se in scheduled_events %}
        <div class="modal fade" id="editEventModal-{{ se.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Scheduled Event #{{ se.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/events/{{ selected_tournament_id }}/{{ se.id }}/update" method="post">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <div class="modal-body">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label text-muted">Event</label>
                      <select class="form-select" name="event_id" required>
                        {% for e in events %}
                        <option value="{{ e.id }}" {% if e.id == se.event_id %}selected{% endif %}>{{ e.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Type</label>
                      <select class="form-select" name="contact_type" required>
                        <option value="Contact" {% if se.contact_type == "Contact" %}selected{% endif %}>Contact</option>
                        <option value="Non-Contact" {% if se.contact_type != "Contact" %}selected{% endif %}>Non-Contact</option>
                      </select>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label text-muted">Status</label>
                      <select class="form-select" name="status" required>
                        <option value="Scheduled" {% if se.status == "Scheduled" %}selected{% endif %}>Scheduled</option>
                        <option value="Ongoing" {% if se.status == "Ongoing" %}selected{% endif %}>Ongoing</option>
                        <option value="Finished" {% if se.status == "Finished" %}selected{% endif %}>Finished</option>
                        <option value="Cancelled" {% if se.status == "Cancelled" %}selected{% endif %}>Cancelled</option>
                      </select>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label text-muted">Location</label>
                      <input class="form-control" name="location" value="{{ se.location | default(value="") }}" />
                    </div>
                    <div class="col-md-6">
                      <label class="form-label text-muted">Event Time</label>
                      <input class="form-control" name="event_time" value="{{ se.event_time | default(value="") }}" />
                    </div>
                    <div class="col-md-4">
                      <label class="form-label text-muted">Point System (Contact only)</label>
                      <select class="form-select" name="point_system">
                        <option value="">(auto)</option>
                        <option value="5-10 points" {% if se.point_system == "5-10 points" %}selected{% endif %}>5-10 points</option>
                        <option value="Must 8/10 points" {% if se.point_system == "Must 8/10 points" %}selected{% endif %}>Must 8/10 points</option>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label text-muted">Time Rule</label>
                      <select class="form-select" name="time_rule">
                        <option value="">(default)</option>
                        <option value="1 round | 1 minute" {% if se.time_rule == "1 round | 1 minute" %}selected{% endif %}>1 round | 1 minute</option>
                        <option value="1 round | 2 minutes" {% if se.time_rule == "1 round | 2 minutes" %}selected{% endif %}>1 round | 2 minutes</option>
                        <option value="3 rounds | 1 minute" {% if se.time_rule == "3 rounds | 1 minute" %}selected{% endif %}>3 rounds | 1 minute</option>
                        <option value="No time limit" {% if se.time_rule == "No time limit" %}selected{% endif %}>No time limit</option>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label text-muted">Draw System (Contact only)</label>
                      <select class="form-select" name="draw_system">
                        <option value="">(none)</option>
                        <option value="Extension" {% if se.draw_system == "Extension" %}selected{% endif %}>Extension</option>
                        <option value="First point Advantage" {% if se.draw_system == "First point Advantage" %}selected{% endif %}>First point Advantage</option>
                      </select>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label text-muted">Gender Division</label>
                      <select class="form-select" name="division_id" required>
                        <option value="">(none)</option>
                        {% for d in divisions %}
                        <option value="{{ d.id }}" {% if se.division_id and d.id == se.division_id %}selected{% endif %}>{{ d.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label text-muted">Weight Class</label>
                      <select class="form-select" name="weight_class_id" required>
                        <option value="">(none)</option>
                        {% for w in weight_classes %}
                        <option value="{{ w.id }}" {% if se.weight_class_id and w.id == se.weight_class_id %}selected{% endif %}>{{ w.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
        {% endif %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
  </body>
</html>
