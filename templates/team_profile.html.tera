<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Team Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
          <div class="d-flex align-items-center gap-3">
            {% if team.logo_url %}
            <img src="{{ team.logo_url }}" alt="Team logo" style="width: 56px; height: 56px; object-fit: cover; border-radius: 14px;">
            {% else %}
            <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; border-radius: 14px;">?</div>
            {% endif %}
            <div>
              <h1 class="fw-bold mb-1">{{ team.name }}</h1>
              <p class="text-cream-75 mb-0">Tournament: {{ tournament_name }}</p>
            </div>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2">
            <form action="/{{ tournament_slug }}/teams/{{ team.id }}" method="get" class="d-flex flex-wrap gap-2">
              <input class="form-control" name="q" placeholder="Search players" value="{{ search_query | default(value="") }}" />
              <select class="form-select" name="sort">
                <option value="name" {% if sort_by == "name" %}selected{% endif %}>Sort: Name</option>
                <option value="rank" {% if sort_by == "rank" %}selected{% endif %}>Sort: Rank</option>
                <option value="weight" {% if sort_by == "weight" %}selected{% endif %}>Sort: Weight Class</option>
              </select>
              <select class="form-select" name="dir">
                <option value="asc" {% if sort_dir == "asc" %}selected{% endif %}>Asc</option>
                <option value="desc" {% if sort_dir == "desc" %}selected{% endif %}>Desc</option>
              </select>
              <button class="btn btn-outline-light" type="submit">Apply</button>
            </form>
            <a class="btn btn-outline-light" href="/{{ tournament_slug }}/teams">Back to Teams</a>
          </div>
        </header>

        

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Entered Divisions</h3>
          <div class="d-flex flex-wrap gap-2">
            {% for division in team.divisions %}
            <span class="badge text-bg-light text-ink">{{ division.name }}</span>
            {% else %}
            <span class="text-cream-60">None</span>
            {% endfor %}
          </div>
        </section>

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Entered Categories</h3>
          <div class="d-flex flex-wrap gap-2">
            {% for category in team.categories %}
            <span class="badge text-bg-light text-ink">{{ category.name }}</span>
            {% else %}
            <span class="text-cream-60">None</span>
            {% endfor %}
          </div>
        </section>

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Entered Events</h3>
          <div class="d-flex flex-wrap gap-2">
            {% for event in team.events %}
            <span class="badge text-bg-light text-ink">{{ event.name }}</span>
            {% else %}
            <span class="text-cream-60">None</span>
            {% endfor %}
          </div>
        </section>

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-3">Add Player</h3>
          <form action="/{{ tournament_slug }}/teams/{{ team.id }}/members" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
            <div class="col-md-4">
              <label class="form-label text-cream-60">Player Name</label>
              <input class="form-control" name="name" placeholder="Player name" />
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Rank</label>
              <input class="form-control" name="rank" placeholder="Rank" />
            </div>
            <div class="col-md-3">
              <label class="form-label text-cream-60">Weight Class</label>
              <input class="form-control" name="weight_class" placeholder="Weight class" />
            </div>
            <div class="col-md-2">
              <label class="form-label text-cream-60">Photo</label>
              <input class="form-control" type="file" name="photo_file" accept="image/*" />
            </div>
            <div class="col-md-10">
              <label class="form-label text-cream-60">Notes</label>
              <input class="form-control" name="notes" placeholder="Notes" />
            </div>
            <div class="col-md-2 d-grid">
              <button class="btn btn-outline-light" type="submit">Add Player</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <h3 class="fw-semibold mb-3">Players</h3>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Photo</th>
                  <th>Name</th>
                  <th>Rank</th>
                  <th>Weight Class</th>
                  <th>Notes</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for member in team.members %}
                <tr>
                  <td colspan="6">
                    <form action="/{{ tournament_slug }}/teams/members/{{ member.id }}/update" method="post" enctype="multipart/form-data" class="row g-2 align-items-center">
                      <div class="col-md-1">
                        {% if member.photo_url %}
                        <img src="{{ member.photo_url }}" alt="Player photo" style="width: 42px; height: 42px; object-fit: cover; border-radius: 12px;">
                        {% else %}
                        <div class="bg-light text-dark d-flex align-items-center justify-content-center" style="width: 42px; height: 42px; border-radius: 12px;">?</div>
                        {% endif %}
                      </div>
                      <div class="col-md-3">
                        <input class="form-control form-control-sm" name="name" value="{{ member.name }}" />
                      </div>
                      <div class="col-md-2">
                        <input class="form-control form-control-sm" name="rank" value="{{ member.rank | default(value="") }}" placeholder="Rank" />
                        <div class="form-check mt-1">
                          <input class="form-check-input" type="checkbox" name="clear_rank" id="clear-rank-{{ member.id }}">
                          <label class="form-check-label small" for="clear-rank-{{ member.id }}">Clear rank</label>
                        </div>
                      </div>
                      <div class="col-md-2">
                        <input class="form-control form-control-sm" name="weight_class" value="{{ member.weight_class | default(value="") }}" placeholder="Weight class" />
                        <div class="form-check mt-1">
                          <input class="form-check-input" type="checkbox" name="clear_weight_class" id="clear-weight-{{ member.id }}">
                          <label class="form-check-label small" for="clear-weight-{{ member.id }}">Clear weight</label>
                        </div>
                      </div>
                      <div class="col-md-2">
                        <input class="form-control form-control-sm" type="file" name="photo_file" accept="image/*" />
                        <div class="form-check mt-1">
                          <input class="form-check-input" type="checkbox" name="clear_photo" id="clear-photo-{{ member.id }}">
                          <label class="form-check-label small" for="clear-photo-{{ member.id }}">Clear photo</label>
                        </div>
                      </div>
                      <div class="col-md-2">
                        <input class="form-control form-control-sm" name="notes" value="{{ member.notes | default(value="") }}" placeholder="Notes" />
                        <div class="form-check mt-1">
                          <input class="form-check-input" type="checkbox" name="clear_notes" id="clear-notes-{{ member.id }}">
                          <label class="form-check-label small" for="clear-notes-{{ member.id }}">Clear notes</label>
                        </div>
                      </div>
                      <div class="col-md-1 d-flex justify-content-end gap-2">
                        <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        <button class="btn btn-sm btn-outline-danger" type="submit" formaction="/{{ tournament_slug }}/teams/members/{{ member.id }}/delete" formmethod="post">
                          Delete
                        </button>
                      </div>
                    </form>
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="6" class="text-cream-60">No players yet.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
