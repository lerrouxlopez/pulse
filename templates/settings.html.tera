<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Tournament Settings</h1>
            <p class="text-cream-75 mb-0">Configure {{ tournament_name }}.</p>
          </div>
          <div class="d-flex flex-column align-items-end gap-2">
            {% if is_owner %}
            <form action="/tournaments/new" method="post" class="d-flex align-items-center gap-2">
              <input class="form-control form-control-sm" name="name" placeholder="Tournament name" required />
              <button class="btn btn-outline-light" type="submit">Create New Tournament</button>
            </form>
            {% endif %}
            {% if not is_setup %}
            <form action="/{{ tournament_slug }}/settings/setup/complete" method="post" class="d-flex flex-column align-items-end">
              <button class="btn btn-primary shadow-glow" type="submit" {% if not can_complete_setup %}disabled{% endif %}>
                Complete Setup
              </button>
              {% if not can_complete_setup %}
              <p class="text-cream-60 mt-2 mb-0 text-end">Add at least one item in each tab to enable setup completion.</p>
              {% endif %}
            </form>
            {% endif %}
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel">
          <ul class="nav nav-tabs" id="settingsTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'branding' %}active{% endif %}" id="branding-tab" data-bs-toggle="tab" data-bs-target="#branding-pane" type="button" role="tab">
                Branding
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'divisions' %}active{% endif %}" id="divisions-tab" data-bs-toggle="tab" data-bs-target="#divisions-pane" type="button" role="tab">
                Gender Divisions
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'categories' %}active{% endif %}" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories-pane" type="button" role="tab">
                Age Categories
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'weight' %}active{% endif %}" id="weight-tab" data-bs-toggle="tab" data-bs-target="#weight-pane" type="button" role="tab">
                Weight Class
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'events' %}active{% endif %}" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-pane" type="button" role="tab">
                Matches / Events
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'roles' %}active{% endif %}" id="roles-tab" data-bs-toggle="tab" data-bs-target="#roles-pane" type="button" role="tab">
                Roles
              </button>
            </li>
          </ul>

          <div class="tab-content pt-4" id="settingsTabsContent">
            <div class="tab-pane fade {% if active_tab == 'branding' %}show active{% endif %}" id="branding-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Tournament Name</h5>
                  <form action="/{{ tournament_slug }}/settings/tournament/name" method="post" class="d-flex flex-wrap gap-2">
                    <input class="form-control flex-grow-1" name="name" value="{{ tournament_name }}" required />
                    <button class="btn btn-outline-light" type="submit">Save Name</button>
                  </form>
                </div>
              </div>

              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">White Label</h5>
                  <p class="text-cream-60 mb-3">Update logo and theme colors for this tournament.</p>
                  <form action="/{{ tournament_slug }}/settings/tournament/branding" method="post" enctype="multipart/form-data" class="row g-3">
                    <div class="col-lg-4">
                      <label class="form-label text-muted">Tournament Logo</label>
                      <input class="form-control" type="file" name="logo_file" accept="image/png,image/jpeg" />
                      <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="clear_logo" id="clear-tournament-logo">
                        <label class="form-check-label small" for="clear-tournament-logo">Clear logo</label>
                      </div>
                      {% if tournament_logo_url %}
                      <img src="{{ tournament_logo_url }}" alt="Tournament logo" class="mt-2" style="width: 96px; height: 96px; border-radius: 16px; object-fit: cover;">
                      {% endif %}
                    </div>
                    <div class="col-lg-8">
                      <div class="row g-2 mb-3">
                        <div class="col-md-8">
                          <label class="form-label text-muted">Preset Themes</label>
                          <select class="form-select" id="branding-preset">
                            <option value="">Custom (no preset)</option>
                            <option value="classic">Classic Pulse</option>
                            <option value="forest">Forest Arena</option>
                            <option value="sunset">Sunset Fight</option>
                            <option value="mono">Monochrome Pro</option>
                            <option value="royal">Royal Blue</option>
                            <option value="volcanic">Volcanic Red</option>
                            <option value="oceanic">Oceanic Teal</option>
                            <option value="golden">Golden Night</option>
                            <option value="mint">Mint Breeze</option>
                            <option value="grape">Grape Pop</option>
                            <option value="ember">Ember Steel</option>
                            <option value="citrus">Citrus Punch</option>
                            <option value="sandstone">Sandstone Calm</option>
                            <option value="midnight">Midnight Neon</option>
                          </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                          <button class="btn btn-outline-secondary w-100" type="button" id="apply-branding-preset">Apply Preset</button>
                        </div>
                      </div>
                      <div class="row g-3">
                        <div class="col-md-4">
                          <label class="form-label text-muted">Primary</label>
                          <input class="form-control form-control-color w-100 js-branding-color" type="color" name="theme_primary_color" value="{{ theme_primary_color }}">
                        </div>
                        <div class="col-md-4">
                          <label class="form-label text-muted">Accent</label>
                          <input class="form-control form-control-color w-100 js-branding-color" type="color" name="theme_accent_color" value="{{ theme_accent_color }}">
                        </div>
                        <div class="col-md-4">
                          <label class="form-label text-muted">Background</label>
                          <input class="form-control form-control-color w-100 js-branding-color" type="color" name="theme_background_color" value="{{ theme_background_color }}">
                        </div>
                        <div class="col-md-4">
                          <label class="form-label text-muted">Navigation Background</label>
                          <input class="form-control form-control-color w-100 js-branding-color" type="color" name="nav_background_color" value="{{ nav_background_color }}">
                        </div>
                        <div class="col-md-4">
                          <label class="form-label text-muted">Navigation Text</label>
                          <input class="form-control form-control-color w-100 js-branding-color" type="color" name="nav_text_color" value="{{ nav_text_color }}">
                        </div>
                      </div>
                      <div class="mt-3 p-3 rounded-3" style="background: {{ theme_background_color }}; border: 1px solid #e5e7eb;">
                        <span class="badge" style="background: {{ theme_primary_color }}; color: #fff;">Primary</span>
                        <span class="badge ms-2" style="background: {{ theme_accent_color }}; color: #fff;">Accent</span>
                        <span class="badge ms-2" style="background: {{ nav_background_color }}; color: {{ nav_text_color }};">Nav</span>
                      </div>
                    </div>
                    <div class="col-12">
                      <button class="btn btn-outline-light" type="submit">Save Branding</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'divisions' %}show active{% endif %}" id="divisions-pane" role="tabpanel">
              <form action="/{{ tournament_slug }}/settings/divisions" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New division name" />
                <button class="btn btn-outline-light" type="submit">Add Division</button>
              </form>
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Default Divisions</h5>
                  <p class="text-cream-60 mb-3">Quick add standard options.</p>
                  <div class="d-flex flex-wrap gap-2">
                    {% set male_exists = "male division" in division_names %}
                    <form action="/{{ tournament_slug }}/settings/divisions" method="post" class="m-0">
                      <input type="hidden" name="name" value="Male Division" />
                      <button class="btn btn-outline-light" type="submit" {% if male_exists %}disabled{% endif %}>
                        {% if male_exists %}Male Division (Added){% else %}Add Male Division{% endif %}
                      </button>
                    </form>
                    {% set female_exists = "female division" in division_names %}
                    <form action="/{{ tournament_slug }}/settings/divisions" method="post" class="m-0">
                      <input type="hidden" name="name" value="Female Division" />
                      <button class="btn btn-outline-light" type="submit" {% if female_exists %}disabled{% endif %}>
                        {% if female_exists %}Female Division (Added){% else %}Add Female Division{% endif %}
                      </button>
                    </form>
                  </div>
                </div>
              </div>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Division</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in divisions %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/divisions/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/divisions/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No divisions yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'categories' %}show active{% endif %}" id="categories-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Categories</h5>
                  <p class="text-cream-60 mb-3">Select from the standard category list to add multiple at once.</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="select-all-categories" data-group="categories" />
                    <label class="form-check-label" for="select-all-categories">Select all</label>
                  </div>
                  {% set category_options = [
                    "Up to 15 years",
                    "6-8 years",
                    "16+ years"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/categories/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-2">
                      {% for option in category_options %}
                      {% set option_key = option | lower %}
                      {% set already_added = option_key in category_names %}
                      <div class="col-12 col-md-6">
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="category-option-{{ loop.index }}" data-group="categories" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="category-option-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Categories</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/categories" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New category name" />
                <button class="btn btn-outline-light" type="submit">Add Category</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Category</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in categories %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/categories/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/categories/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No categories yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'weight' %}show active{% endif %}" id="weight-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Weight Classes</h5>
                  <p class="text-cream-60 mb-3">Select from the standard weight list to add multiple at once.</p>
                  {% set weight_men_women = [
                    "Bantam Weight: -55 kg (Men), -48 kg (Women)",
                    "Feather Weight: -60 kg (Men), -52 kg (Women)",
                    "Light Weight: -66 kg (Men), -57 kg (Women)",
                    "Welter Weight: -73 kg (Men), -63 kg (Women)",
                    "Middle Weight: -81 kg (Men), -70 kg (Women)",
                    "Cruiser Weight: -90 kg (Men), -78 kg (Women)",
                    "Heavy Weight: -100 kg (Men), -87 kg (Women)",
                    "Super Heavy: 100 kg+ (Men), 87 kg+ (Women)"
                  ] %}
                  {% set weight_boys_girls = [
                    "Mini Division: Under 43 kg (Boys), Under 37 kg (Girls)",
                    "Pinweight: 43 kgs - 47 kgs (Boys), 37 kgs - 40 kgs (Girls)",
                    "Bantamweight: Over 47 kgs - 51 kgs (Boys), Over 40 kgs - 44 kgs (Girls)",
                    "Featherweight: Over 51 kgs - 55 kgs (Boys), Over 44 kgs - 48 kgs (Girls)",
                    "Extra Lightweight: Over 55 kgs - 60 kgs (Boys), Over 48 kgs - 52 kgs (Girls)",
                    "Half Lightweight: Over 60 kgs - 65 kgs (Boys), Over 52 kgs - 56 kgs (Girls)"
                  ] %}
                  {% set weight_kids = [
                    "Kids Division: 38 kg and below / Over 38-40 kg / Over 40-42 kg"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/weight-classes/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-3">
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Men / Women</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-men" data-group="weight-men" />
                          <label class="form-check-label" for="select-all-weight-men">Select all (Men / Women)</label>
                        </div>
                        {% for option in weight_men_women %}
                        {% set option_key = option | lower %}
                        {% set already_added = option_key in weight_names %}
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-men-{{ loop.index }}" data-group="weight-men" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="weight-men-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                        {% endfor %}
                      </div>
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Boys / Girls</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-youth" data-group="weight-youth" />
                          <label class="form-check-label" for="select-all-weight-youth">Select all (Boys / Girls)</label>
                        </div>
                        {% for option in weight_boys_girls %}
                        {% set option_key = option | lower %}
                        {% set already_added = option_key in weight_names %}
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-youth-{{ loop.index }}" data-group="weight-youth" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="weight-youth-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                        {% endfor %}
                      </div>
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Kids Divisions</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-kids" data-group="weight-kids" />
                          <label class="form-check-label" for="select-all-weight-kids">Select all (Kids Divisions)</label>
                        </div>
                        <div class="drawer-grid">
                          {% for option in weight_kids %}
                          {% set option_key = option | lower %}
                          {% set already_added = option_key in weight_names %}
                          <div class="form-check">
                            <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-kids-{{ loop.index }}" data-group="weight-kids" {% if already_added %}checked disabled{% endif %} />
                            <label class="form-check-label" for="weight-kids-{{ loop.index }}">
                              {{ option }}
                              {% if already_added %}
                              <span class="text-cream-60 ms-2">(Added)</span>
                              {% endif %}
                            </label>
                          </div>
                          {% endfor %}
                        </div>
                      </div>
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Weight Classes</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/weight-classes" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New weight class name" />
                <button class="btn btn-outline-light" type="submit">Add Weight</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Weight Class</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in weight_classes %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/weight-classes/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/weight-classes/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No weight classes yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'events' %}show active{% endif %}" id="events-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Events</h5>
                  <p class="text-cream-60 mb-3">Select from the standard event list to add multiple at once.</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="select-all-events" data-group="events" />
                    <label class="form-check-label" for="select-all-events">Select all</label>
                  </div>
                  {% set event_options = [
                    "Non-Traditional Sayaw",
                    "Traditional Sayaw",
                    "Padded Stick",
                    "Padded Point Knife",
                    "Padded Single Live Stick",
                    "Padded Double Live Stick",
                    "Pool Noodle Point",
                    "Single Live Stick",
                    "Double Live Stick",
                    "Bangkaw"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/events/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-2">
                      {% for option in event_options %}
                      {% set option_key = option | lower %}
                      {% set already_added = option_key in event_names %}
                      <div class="col-12 col-md-6">
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="event-option-{{ loop.index }}" data-group="events" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="event-option-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Events</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/events" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New event name" />
                <button class="btn btn-outline-light" type="submit">Add Event</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Event</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in events %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/events/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/events/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No events yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'roles' %}show active{% endif %}" id="roles-pane" role="tabpanel">
              <div class="row g-4">
                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">Create Role</h5>
                  <p class="text-cream-60">Define a role and then assign permissions below.</p>
                  {% if not is_owner %}
                  <p class="text-cream-60 mb-3">Only the owner can manage roles and permissions.</p>
                  {% endif %}
                  <form action="/{{ tournament_slug }}/settings/roles" method="post" class="d-flex flex-wrap gap-2 mb-4">
                    <input class="form-control flex-grow-1" name="name" placeholder="Role name" {% if not is_owner %}disabled{% endif %} />
                    <button class="btn btn-outline-light" type="submit" {% if not is_owner %}disabled{% endif %}>Add Role</button>
                  </form>

                  <h5 class="fw-semibold mb-2">Roles & Permissions</h5>
                  <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                      <thead>
                        <tr>
                          <th>Role</th>
                          <th>Permissions</th>
                          <th class="text-end">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for role in roles %}
                        <tr>
                          <td class="fw-semibold">
                            {{ role.name }}{% if role.is_owner %} <span class="text-cream-60">(Owner)</span>{% endif %}
                          </td>
                          <td>
                            <form action="/{{ tournament_slug }}/settings/roles/{{ role.id }}/permissions" method="post" class="d-flex flex-wrap gap-2">
                              {% for perm in permissions %}
                              <label class="form-check form-check-inline text-cream-60 mb-0">
                                <input class="form-check-input" type="checkbox" name="permissions" value="{{ perm }}"
                                  {% if perm in role.permissions %}checked{% endif %}
                                  {% if role.is_owner %}disabled{% endif %} />
                                <span class="form-check-label text-cream-75">{{ perm | title }}</span>
                              </label>
                              {% endfor %}
                              <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-light" type="submit" {% if role.is_owner or not is_owner %}disabled{% endif %}>Save</button>
                              </div>
                            </form>
                          </td>
                          <td class="text-end">
                            <form action="/{{ tournament_slug }}/settings/roles/{{ role.id }}/delete" method="post">
                              <button class="btn btn-sm btn-outline-danger" type="submit" {% if role.is_owner or not is_owner %}disabled{% endif %}>Delete</button>
                            </form>
                          </td>
                        </tr>
                        {% else %}
                        <tr>
                          <td colspan="3" class="text-cream-60">No roles yet.</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">Create Tournament User</h5>
                  <p class="text-cream-60">Create a tournament-only account and assign a role immediately.</p>
                  <p class="text-cream-60">
                    Tournament users sign in at
                    <a href="{{ tournament_login_path }}" class="js-tournament-login-link" target="_blank" rel="noopener noreferrer">{{ tournament_login_path }}</a>.
                  </p>
                  <form action="/{{ tournament_slug }}/settings/roles/users/create" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-2 mb-4">
                    <input class="form-control" name="name" placeholder="Full name" {% if not is_owner %}disabled{% endif %} />
                    <input class="form-control" name="email" placeholder="Email" {% if not is_owner %}disabled{% endif %} />
                    <input class="form-control" type="password" name="password" placeholder="Temporary password" {% if not is_owner %}disabled{% endif %} />
                    <select class="form-select" name="role_id" {% if not is_owner %}disabled{% endif %}>
                      <option value="">Select role</option>
                      {% for role in roles %}
                      <option value="{{ role.id }}">{{ role.name }}</option>
                      {% endfor %}
                    </select>
                    <input class="form-control" type="file" name="photo_file" accept="image/png,image/jpeg" {% if not is_owner %}disabled{% endif %} />
                    <button class="btn btn-outline-light align-self-start" type="submit" {% if not is_owner %}disabled{% endif %}>Create Tournament User</button>
                  </form>

                  <h5 class="fw-semibold mb-2">Tournament Users</h5>
                  <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                      <thead>
                        <tr>
                          <th>User</th>
                          <th>Photo</th>
                          <th>Email</th>
                          <th>Role</th>
                          <th class="text-end">Action</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for user in access_users %}
                        <tr>
                          <td>
                            <div class="fw-semibold">{{ user.name }}</div>
                          </td>
                          <td>
                            <div class="d-flex align-items-center gap-2">
                              <img src="{{ user.photo_url | default(value="/static/placeholders/player-3.svg") }}" alt="User photo" class="match-avatar" />
                            </div>
                          </td>
                          <td>
                            <div class="text-cream-75">{{ user.email }}</div>
                          </td>
                          <td>
                            <div class="text-cream-75">{{ user.role_name | default(value="Unassigned") }}</div>
                          </td>
                          <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                              <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editUserModal-{{ user.id }}" aria-label="Edit user" {% if not is_owner or user.id == tournament_owner_id %}disabled{% endif %}>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                  <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-9.5 9.5a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l9.5-9.5zM11.207 2 3 10.207V13h2.793L14 4.793 11.207 2z"/>
                                </svg>
                              </button>
                            <form action="/{{ tournament_slug }}/settings/roles/users/{{ user.id }}/delete" method="post" class="d-inline">
                              <button class="btn btn-sm btn-outline-danger" type="submit" aria-label="Delete user" {% if not is_owner or user.id == tournament_owner_id %}disabled{% endif %}>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                  <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5.5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6zm2 .5a.5.5 0 0 1 .5-.5h.5a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6z"/>
                                  <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5.5a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1H14a1 1 0 0 1 .5 2zm-3.5 1H5v9a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1V4z"/>
                                </svg>
                              </button>
                            </form>
                            </div>
                          </td>
                        </tr>

                        {% else %}
                        <tr>
                          <td colspan="5" class="text-cream-60">No users added yet.</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>

                {% for user in access_users %}
                <div class="modal fade" id="editUserModal-{{ user.id }}" tabindex="-1" aria-labelledby="editUserModalLabel-{{ user.id }}" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content text-ink">
                      <div class="modal-header">
                        <h5 class="modal-title" id="editUserModalLabel-{{ user.id }}">Edit Tournament User</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <form action="/{{ tournament_slug }}/settings/roles/users/{{ user.id }}/update" method="post" enctype="multipart/form-data">
                        <div class="modal-body">
                          <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" name="name" value="{{ user.name }}" {% if user.id == tournament_owner_id %}disabled{% endif %} />
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" name="email" value="{{ user.email }}" {% if user.id == tournament_owner_id %}disabled{% endif %} />
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select class="form-select" name="role_id" {% if user.id == tournament_owner_id %}disabled{% endif %}>
                              {% for role in roles %}
                              <option value="{{ role.id }}" {% if user.role_id == role.id %}selected{% endif %}>{{ role.name }}</option>
                              {% endfor %}
                            </select>
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Photo</label>
                            <input class="form-control" type="file" name="photo_file" accept="image/png,image/jpeg" {% if user.id == tournament_owner_id %}disabled{% endif %} />
                          </div>

                          <div class="border-top pt-3 mt-2">
                            <div class="fw-semibold mb-2">Change Password</div>
                            <div class="text-muted small mb-2">Leave blank to keep the current password.</div>
                            <div class="mb-2">
                              <label class="form-label">New password</label>
                              <input class="form-control" type="password" name="password" autocomplete="new-password" {% if user.id == tournament_owner_id %}disabled{% endif %} />
                            </div>
                            <div class="mb-0">
                              <label class="form-label">Confirm password</label>
                              <input class="form-control" type="password" name="password_confirm" autocomplete="new-password" {% if user.id == tournament_owner_id %}disabled{% endif %} />
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-primary" {% if not is_owner or user.id == tournament_owner_id %}disabled{% endif %}>Save Changes</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
    <script>
      const selectAllBoxes = document.querySelectorAll(".js-select-all");
      const updateSelectAllState = (group) => {
        const items = Array.from(document.querySelectorAll(`.js-select-item[data-group="${group}"]`))
          .filter((item) => !item.disabled);
        const allChecked = items.length > 0 && items.every((item) => item.checked);
        const selectAll = document.querySelector(`.js-select-all[data-group="${group}"]`);
        if (selectAll) {
          selectAll.checked = allChecked;
        }
      };

      selectAllBoxes.forEach((selectAll) => {
        const group = selectAll.dataset.group;
        selectAll.addEventListener("change", () => {
          document
            .querySelectorAll(`.js-select-item[data-group="${group}"]`)
            .forEach((item) => {
              if (!item.disabled) {
                item.checked = selectAll.checked;
              }
            });
        });
        updateSelectAllState(group);
      });

      document.querySelectorAll(".js-select-item").forEach((item) => {
        item.addEventListener("change", () => updateSelectAllState(item.dataset.group));
      });

      document.querySelectorAll(".js-tournament-login-link").forEach((link) => {
        try {
          const absolute = new URL(link.getAttribute("href"), window.location.origin).toString();
          link.textContent = absolute;
          link.href = absolute;
        } catch (_) {}
      });

      const brandingPresets = {
        classic: {
          theme_primary_color: "#2d62ff",
          theme_accent_color: "#ff6b35",
          theme_background_color: "#f2f3f5",
          nav_background_color: "#0f1426",
          nav_text_color: "#f5efe6"
        },
        forest: {
          theme_primary_color: "#166534",
          theme_accent_color: "#eab308",
          theme_background_color: "#ecfdf5",
          nav_background_color: "#052e16",
          nav_text_color: "#dcfce7"
        },
        sunset: {
          theme_primary_color: "#c2410c",
          theme_accent_color: "#7c3aed",
          theme_background_color: "#fff7ed",
          nav_background_color: "#7c2d12",
          nav_text_color: "#ffedd5"
        },
        mono: {
          theme_primary_color: "#334155",
          theme_accent_color: "#0f172a",
          theme_background_color: "#f8fafc",
          nav_background_color: "#111827",
          nav_text_color: "#e5e7eb"
        },
        royal: {
          theme_primary_color: "#1d4ed8",
          theme_accent_color: "#2563eb",
          theme_background_color: "#eff6ff",
          nav_background_color: "#1e3a8a",
          nav_text_color: "#dbeafe"
        },
        volcanic: {
          theme_primary_color: "#b91c1c",
          theme_accent_color: "#ef4444",
          theme_background_color: "#fef2f2",
          nav_background_color: "#7f1d1d",
          nav_text_color: "#fee2e2"
        },
        oceanic: {
          theme_primary_color: "#0f766e",
          theme_accent_color: "#14b8a6",
          theme_background_color: "#f0fdfa",
          nav_background_color: "#134e4a",
          nav_text_color: "#ccfbf1"
        },
        golden: {
          theme_primary_color: "#a16207",
          theme_accent_color: "#eab308",
          theme_background_color: "#fefce8",
          nav_background_color: "#713f12",
          nav_text_color: "#fef3c7"
        },
        mint: {
          theme_primary_color: "#059669",
          theme_accent_color: "#34d399",
          theme_background_color: "#ecfdf5",
          nav_background_color: "#065f46",
          nav_text_color: "#d1fae5"
        },
        grape: {
          theme_primary_color: "#7c3aed",
          theme_accent_color: "#a78bfa",
          theme_background_color: "#f5f3ff",
          nav_background_color: "#4c1d95",
          nav_text_color: "#ede9fe"
        },
        ember: {
          theme_primary_color: "#ea580c",
          theme_accent_color: "#fb7185",
          theme_background_color: "#fff7ed",
          nav_background_color: "#7c2d12",
          nav_text_color: "#ffedd5"
        },
        citrus: {
          theme_primary_color: "#65a30d",
          theme_accent_color: "#f59e0b",
          theme_background_color: "#f7fee7",
          nav_background_color: "#3f6212",
          nav_text_color: "#ecfccb"
        },
        sandstone: {
          theme_primary_color: "#78716c",
          theme_accent_color: "#a8a29e",
          theme_background_color: "#fafaf9",
          nav_background_color: "#44403c",
          nav_text_color: "#f5f5f4"
        },
        midnight: {
          theme_primary_color: "#06b6d4",
          theme_accent_color: "#22d3ee",
          theme_background_color: "#ecfeff",
          nav_background_color: "#0f172a",
          nav_text_color: "#cffafe"
        }
      };
      const presetSelect = document.getElementById("branding-preset");
      const presetBtn = document.getElementById("apply-branding-preset");
      if (presetSelect && presetBtn) {
        presetBtn.addEventListener("click", () => {
          const selected = presetSelect.value;
          const preset = brandingPresets[selected];
          if (!preset) return;
          Object.entries(preset).forEach(([name, value]) => {
            const input = document.querySelector(`input[name="${name}"]`);
            if (input) input.value = value;
          });
        });
      }
    </script>
  </body>
</html>
