<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/sidebar" %}
      </aside>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Tournament Settings</h1>
            <p class="text-cream-75 mb-0">Configure {{ tournament_name }}.</p>
          </div>
          <div class="d-flex flex-column align-items-end gap-2">
            <form action="/tournaments/new" method="post">
              <input type="hidden" name="name" value="New Tournament" />
              <button class="btn btn-outline-light" type="submit">Create New Tournament</button>
            </form>
            {% if not is_setup %}
            <form action="/{{ tournament_slug }}/settings/setup/complete" method="post" class="d-flex flex-column align-items-end">
              <button class="btn btn-primary shadow-glow" type="submit" {% if not can_complete_setup %}disabled{% endif %}>
                Complete Setup
              </button>
              {% if not can_complete_setup %}
              <p class="text-cream-60 mt-2 mb-0 text-end">Add at least one item in each tab to enable setup completion.</p>
              {% endif %}
            </form>
            {% endif %}
          </div>
        </header>

        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <section class="panel">
          <ul class="nav nav-tabs" id="settingsTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'divisions' %}active{% endif %}" id="divisions-tab" data-bs-toggle="tab" data-bs-target="#divisions-pane" type="button" role="tab">
                Divisions
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'categories' %}active{% endif %}" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories-pane" type="button" role="tab">
                Categories
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'weight' %}active{% endif %}" id="weight-tab" data-bs-toggle="tab" data-bs-target="#weight-pane" type="button" role="tab">
                Weight Class
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'events' %}active{% endif %}" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-pane" type="button" role="tab">
                Events
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'access' %}active{% endif %}" id="access-tab" data-bs-toggle="tab" data-bs-target="#access-pane" type="button" role="tab">
                Access
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link {% if active_tab == 'roles' %}active{% endif %}" id="roles-tab" data-bs-toggle="tab" data-bs-target="#roles-pane" type="button" role="tab">
                Roles
              </button>
            </li>
          </ul>

          <div class="tab-content pt-4" id="settingsTabsContent">
            <div class="tab-pane fade {% if active_tab == 'divisions' %}show active{% endif %}" id="divisions-pane" role="tabpanel">
              <form action="/{{ tournament_slug }}/settings/divisions" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New division name" />
                <button class="btn btn-outline-light" type="submit">Add Division</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Division</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in divisions %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/divisions/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/divisions/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No divisions yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'categories' %}show active{% endif %}" id="categories-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Categories</h5>
                  <p class="text-cream-60 mb-3">Select from the standard category list to add multiple at once.</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="select-all-categories" data-group="categories" />
                    <label class="form-check-label" for="select-all-categories">Select all</label>
                  </div>
                  {% set category_options = [
                    "Up to 15 years",
                    "6-8 years",
                    "16+ years"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/categories/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-2">
                      {% for option in category_options %}
                      {% set option_key = option | lower %}
                      {% set already_added = option_key in category_names %}
                      <div class="col-12 col-md-6">
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="category-option-{{ loop.index }}" data-group="categories" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="category-option-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Categories</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/categories" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New category name" />
                <button class="btn btn-outline-light" type="submit">Add Category</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Category</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in categories %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/categories/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/categories/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No categories yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'weight' %}show active{% endif %}" id="weight-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Weight Classes</h5>
                  <p class="text-cream-60 mb-3">Select from the standard weight list to add multiple at once.</p>
                  {% set weight_men_women = [
                    "Bantam Weight: -55 kg (Men), -48 kg (Women)",
                    "Feather Weight: -60 kg (Men), -52 kg (Women)",
                    "Light Weight: -66 kg (Men), -57 kg (Women)",
                    "Welter Weight: -73 kg (Men), -63 kg (Women)",
                    "Middle Weight: -81 kg (Men), -70 kg (Women)",
                    "Cruiser Weight: -90 kg (Men), -78 kg (Women)",
                    "Heavy Weight: -100 kg (Men), -87 kg (Women)",
                    "Super Heavy: 100 kg+ (Men), 87 kg+ (Women)"
                  ] %}
                  {% set weight_boys_girls = [
                    "Mini Division: Under 43 kg (Boys), Under 37 kg (Girls)",
                    "Pinweight: 43 kgs - 47 kgs (Boys), 37 kgs - 40 kgs (Girls)",
                    "Bantamweight: Over 47 kgs - 51 kgs (Boys), Over 40 kgs - 44 kgs (Girls)",
                    "Featherweight: Over 51 kgs - 55 kgs (Boys), Over 44 kgs - 48 kgs (Girls)",
                    "Extra Lightweight: Over 55 kgs - 60 kgs (Boys), Over 48 kgs - 52 kgs (Girls)",
                    "Half Lightweight: Over 60 kgs - 65 kgs (Boys), Over 52 kgs - 56 kgs (Girls)"
                  ] %}
                  {% set weight_kids = [
                    "Kids Division: 38 kg and below / Over 38-40 kg / Over 40-42 kg"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/weight-classes/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-3">
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Men / Women</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-men" data-group="weight-men" />
                          <label class="form-check-label" for="select-all-weight-men">Select all (Men / Women)</label>
                        </div>
                        {% for option in weight_men_women %}
                        {% set option_key = option | lower %}
                        {% set already_added = option_key in weight_names %}
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-men-{{ loop.index }}" data-group="weight-men" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="weight-men-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                        {% endfor %}
                      </div>
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Boys / Girls</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-youth" data-group="weight-youth" />
                          <label class="form-check-label" for="select-all-weight-youth">Select all (Boys / Girls)</label>
                        </div>
                        {% for option in weight_boys_girls %}
                        {% set option_key = option | lower %}
                        {% set already_added = option_key in weight_names %}
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-youth-{{ loop.index }}" data-group="weight-youth" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="weight-youth-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                        {% endfor %}
                      </div>
                      <div class="col-12 col-lg-6">
                        <p class="text-cream-60 mb-2">Kids Divisions</p>
                        <div class="form-check mb-2">
                          <input class="form-check-input js-select-all" type="checkbox" id="select-all-weight-kids" data-group="weight-kids" />
                          <label class="form-check-label" for="select-all-weight-kids">Select all (Kids Divisions)</label>
                        </div>
                        <div class="drawer-grid">
                          {% for option in weight_kids %}
                          {% set option_key = option | lower %}
                          {% set already_added = option_key in weight_names %}
                          <div class="form-check">
                            <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="weight-kids-{{ loop.index }}" data-group="weight-kids" {% if already_added %}checked disabled{% endif %} />
                            <label class="form-check-label" for="weight-kids-{{ loop.index }}">
                              {{ option }}
                              {% if already_added %}
                              <span class="text-cream-60 ms-2">(Added)</span>
                              {% endif %}
                            </label>
                          </div>
                          {% endfor %}
                        </div>
                      </div>
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Weight Classes</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/weight-classes" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New weight class name" />
                <button class="btn btn-outline-light" type="submit">Add Weight</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Weight Class</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in weight_classes %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/weight-classes/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/weight-classes/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No weight classes yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'events' %}show active{% endif %}" id="events-pane" role="tabpanel">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h5 class="fw-semibold mb-2">Quick Add Events</h5>
                  <p class="text-cream-60 mb-3">Select from the standard event list to add multiple at once.</p>
                  <div class="form-check mb-2">
                    <input class="form-check-input js-select-all" type="checkbox" id="select-all-events" data-group="events" />
                    <label class="form-check-label" for="select-all-events">Select all</label>
                  </div>
                  {% set event_options = [
                    "Non-Traditional Sayaw",
                    "Traditional Sayaw",
                    "Padded Stick",
                    "Padded Point Knife",
                    "Padded Single Live Stick",
                    "Padded Double Live Stick",
                    "Pool Noodle Point",
                    "Single Live Stick",
                    "Double Live Stick",
                    "Bangkaw"
                  ] %}
                  <form action="/{{ tournament_slug }}/settings/events/bulk" method="post" class="d-flex flex-column gap-2">
                    <div class="row g-2">
                      {% for option in event_options %}
                      {% set option_key = option | lower %}
                      {% set already_added = option_key in event_names %}
                      <div class="col-12 col-md-6">
                        <div class="form-check">
                          <input class="form-check-input js-select-item" type="checkbox" name="options" value="{{ option }}" id="event-option-{{ loop.index }}" data-group="events" {% if already_added %}checked disabled{% endif %} />
                          <label class="form-check-label" for="event-option-{{ loop.index }}">
                            {{ option }}
                            {% if already_added %}
                            <span class="text-cream-60 ms-2">(Added)</span>
                            {% endif %}
                          </label>
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                    <div>
                      <button class="btn btn-outline-light" type="submit">Add Selected Events</button>
                    </div>
                  </form>
                </div>
              </div>
              <form action="/{{ tournament_slug }}/settings/events" method="post" class="d-flex flex-wrap gap-2 mb-3">
                <input class="form-control flex-grow-1" name="name" placeholder="New event name" />
                <button class="btn btn-outline-light" type="submit">Add Event</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th scope="col">Event</th>
                      <th scope="col" class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in events %}
                    <tr>
                      <td>
                        <form action="/{{ tournament_slug }}/settings/events/{{ item.id }}/update" method="post" class="d-flex gap-2">
                          <input class="form-control" name="name" value="{{ item.name }}" />
                          <button class="btn btn-sm btn-outline-light" type="submit">Save</button>
                        </form>
                      </td>
                      <td class="text-end">
                        <form action="/{{ tournament_slug }}/settings/events/{{ item.id }}/delete" method="post">
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="2" class="text-cream-60">No events yet.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'access' %}show active{% endif %}" id="access-pane" role="tabpanel">
              <div class="row g-4">
                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">Invite User</h5>
                  <p class="text-cream-60">Add another user by email to access this tournament.</p>
                  <form action="/{{ tournament_slug }}/settings/invite" method="post" class="d-flex flex-wrap gap-2">
                    <input class="form-control flex-grow-1" name="email" placeholder="user@email.com" />
                    <button class="btn btn-outline-light" type="submit">Send Invite</button>
                  </form>
                </div>
                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">People With Access</h5>
                  <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                      <thead>
                        <tr>
                          <th>Name</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for user in access_users %}
                        <tr>
                          <td>{{ user.name }}</td>
                        </tr>
                        {% else %}
                        <tr>
                          <td class="text-cream-60">No users added yet.</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <div class="tab-pane fade {% if active_tab == 'roles' %}show active{% endif %}" id="roles-pane" role="tabpanel">
              <div class="row g-4">
                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">Create Role</h5>
                  <p class="text-cream-60">Define a role and then assign permissions below.</p>
                  {% if not is_owner %}
                  <p class="text-cream-60 mb-3">Only the owner can manage roles and permissions.</p>
                  {% endif %}
                  <form action="/{{ tournament_slug }}/settings/roles" method="post" class="d-flex flex-wrap gap-2 mb-4">
                    <input class="form-control flex-grow-1" name="name" placeholder="Role name" {% if not is_owner %}disabled{% endif %} />
                    <button class="btn btn-outline-light" type="submit" {% if not is_owner %}disabled{% endif %}>Add Role</button>
                  </form>

                  <h5 class="fw-semibold mb-2">Roles & Permissions</h5>
                  <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                      <thead>
                        <tr>
                          <th>Role</th>
                          <th>Permissions</th>
                          <th class="text-end">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for role in roles %}
                        <tr>
                          <td class="fw-semibold">
                            {{ role.name }}{% if role.is_owner %} <span class="text-cream-60">(Owner)</span>{% endif %}
                          </td>
                          <td>
                            <form action="/{{ tournament_slug }}/settings/roles/{{ role.id }}/permissions" method="post" class="d-flex flex-wrap gap-2">
                              {% for perm in permissions %}
                              <label class="form-check form-check-inline text-cream-60 mb-0">
                                <input class="form-check-input" type="checkbox" name="permissions" value="{{ perm }}"
                                  {% if perm in role.permissions %}checked{% endif %}
                                  {% if role.is_owner %}disabled{% endif %} />
                                <span class="form-check-label text-cream-75">{{ perm | title }}</span>
                              </label>
                              {% endfor %}
                              <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-light" type="submit" {% if role.is_owner or not is_owner %}disabled{% endif %}>Save</button>
                              </div>
                            </form>
                          </td>
                          <td class="text-end">
                            <form action="/{{ tournament_slug }}/settings/roles/{{ role.id }}/delete" method="post">
                              <button class="btn btn-sm btn-outline-danger" type="submit" {% if role.is_owner or not is_owner %}disabled{% endif %}>Delete</button>
                            </form>
                          </td>
                        </tr>
                        {% else %}
                        <tr>
                          <td colspan="3" class="text-cream-60">No roles yet.</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="col-lg-6">
                  <h5 class="fw-semibold mb-2">Create User</h5>
                  <p class="text-cream-60">Owner can create users and assign a role immediately.</p>
                  <form action="/{{ tournament_slug }}/settings/roles/users/create" method="post" class="d-flex flex-column gap-2 mb-4">
                    <input class="form-control" name="name" placeholder="Full name" {% if not is_owner %}disabled{% endif %} />
                    <input class="form-control" name="email" placeholder="Email" {% if not is_owner %}disabled{% endif %} />
                    <input class="form-control" type="password" name="password" placeholder="Temporary password" {% if not is_owner %}disabled{% endif %} />
                    <select class="form-select" name="role_id" {% if not is_owner %}disabled{% endif %}>
                      <option value="">Select role</option>
                      {% for role in roles %}
                      <option value="{{ role.id }}">{{ role.name }}</option>
                      {% endfor %}
                    </select>
                    <button class="btn btn-outline-light align-self-start" type="submit" {% if not is_owner %}disabled{% endif %}>Create User</button>
                  </form>

                  <h5 class="fw-semibold mb-2">Add Existing User</h5>
                  <p class="text-cream-60">Attach an existing user account to this tournament.</p>
                  <form action="/{{ tournament_slug }}/settings/roles/users/add" method="post" class="d-flex flex-column gap-2 mb-4">
                    <select class="form-select" name="user_id" {% if not is_owner %}disabled{% endif %}>
                      <option value="">Select user</option>
                      {% for user in available_users %}
                      <option value="{{ user.id }}">{{ user.name }} ({{ user.email }})</option>
                      {% endfor %}
                    </select>
                    <select class="form-select" name="role_id" {% if not is_owner %}disabled{% endif %}>
                      <option value="">Select role</option>
                      {% for role in roles %}
                      <option value="{{ role.id }}">{{ role.name }}</option>
                      {% endfor %}
                    </select>
                    <button class="btn btn-outline-light align-self-start" type="submit" {% if not is_owner %}disabled{% endif %}>Add User</button>
                  </form>

                  <h5 class="fw-semibold mb-2">Users</h5>
                  <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                      <thead>
                        <tr>
                          <th>User</th>
                          <th>Email</th>
                          <th>Role</th>
                          <th class="text-end">Action</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for user in access_users %}
                        <tr>
                          <td>
                            <input class="form-control" name="name" value="{{ user.name }}" form="user-update-{{ user.id }}" {% if not is_owner %}disabled{% endif %} />
                          </td>
                          <td>
                            <input class="form-control" name="email" value="{{ user.email }}" form="user-update-{{ user.id }}" {% if not is_owner %}disabled{% endif %} />
                          </td>
                          <td>
                            <select class="form-select" name="role_id" form="user-update-{{ user.id }}" {% if not is_owner or user.id == tournament_owner_id %}disabled{% endif %}>
                              {% for role in roles %}
                              <option value="{{ role.id }}" {% if user.role_id == role.id %}selected{% endif %}>{{ role.name }}</option>
                              {% endfor %}
                            </select>
                          </td>
                          <td class="text-end">
                              <div class="d-flex justify-content-end gap-2">
                                <form id="user-update-{{ user.id }}" action="/{{ tournament_slug }}/settings/roles/users/{{ user.id }}/update" method="post">
                                  <button class="btn btn-sm btn-outline-light" type="submit" {% if not is_owner %}disabled{% endif %}>Save</button>
                                </form>
                              </div>
                            <form action="/{{ tournament_slug }}/settings/roles/users/{{ user.id }}/delete" method="post" class="d-inline">
                              <button class="btn btn-sm btn-outline-danger" type="submit" {% if not is_owner or user.id == tournament_owner_id %}disabled{% endif %}>Delete</button>
                            </form>
                          </td>
                        </tr>
                        {% else %}
                        <tr>
                          <td colspan="4" class="text-cream-60">No users added yet.</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script>
      const selectAllBoxes = document.querySelectorAll(".js-select-all");
      const updateSelectAllState = (group) => {
        const items = Array.from(document.querySelectorAll(`.js-select-item[data-group="${group}"]`))
          .filter((item) => !item.disabled);
        const allChecked = items.length > 0 && items.every((item) => item.checked);
        const selectAll = document.querySelector(`.js-select-all[data-group="${group}"]`);
        if (selectAll) {
          selectAll.checked = allChecked;
        }
      };

      selectAllBoxes.forEach((selectAll) => {
        const group = selectAll.dataset.group;
        selectAll.addEventListener("change", () => {
          document
            .querySelectorAll(`.js-select-item[data-group="${group}"]`)
            .forEach((item) => {
              if (!item.disabled) {
                item.checked = selectAll.checked;
              }
            });
        });
        updateSelectAllState(group);
      });

      document.querySelectorAll(".js-select-item").forEach((item) => {
        item.addEventListener("change", () => updateSelectAllState(item.dataset.group));
      });
    </script>
  </body>
</html>
