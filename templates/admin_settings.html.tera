<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pulse - Admin Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/site.css" />
  </head>
  <body class="bg-ink text-cream dashboard-body">
    <div class="dashboard-wrap">
      <aside class="sidebar">
        {% include "partials/admin_sidebar" %}
      </aside>

      <button type="button" class="sidebar-float-toggle" data-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">
        <svg class="icon-collapse" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-expand" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <main class="content">
        <header class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-3">
          <div>
            <h1 class="fw-bold mb-1">Settings</h1>
            <p class="text-cream-75 mb-0">Divisions, categories, weight classes, and event definitions per tournament.</p>
          </div>
          <a class="btn btn-outline-light" href="/admin/events">Back to Events</a>
        </header>

        {% if error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success" role="alert">{{ success }}</div>
        {% endif %}

        <section class="panel mb-4">
          <h3 class="fw-semibold mb-2">Tournament</h3>
          <form method="get" action="/admin/settings" class="d-flex flex-wrap gap-2 align-items-center">
            <select class="form-select" name="tournament_id" onchange="this.form.submit()">
              {% for t in tournaments %}
              <option value="{{ t.id }}" {% if selected_tournament_id and t.id == selected_tournament_id %}selected{% endif %}>
                {{ t.name }} ({{ t.slug }})
              </option>
              {% endfor %}
            </select>
            <noscript><button class="btn btn-outline-light" type="submit">Load</button></noscript>
          </form>
        </section>

        {% if not selected_tournament_id %}
          <div class="text-cream-60">No tournaments available.</div>
        {% else %}
        <section class="panel mb-4">
          <div class="row g-4">
            <div class="col-12 col-lg-6">
              <h3 class="fw-semibold mb-3">Divisions</h3>
              <form action="/admin/settings/divisions/create" method="post" class="d-flex gap-2 mb-3">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <input class="form-control" name="name" placeholder="e.g. Male Division" required />
                <button class="btn btn-outline-light" type="submit">Add</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th style="width: 80px">ID</th>
                      <th>Name</th>
                      <th class="text-end" style="width: 220px">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in divisions %}
                    <tr>
                      <td class="text-cream-60">#{{ item.id }}</td>
                      <td class="fw-semibold">{{ item.name }}</td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                          <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editDivisionModal-{{ item.id }}">Edit</button>
                          <form action="/admin/settings/divisions/{{ item.id }}/delete" method="post" onsubmit="return confirm('Delete this division?');">
                            <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="3" class="text-cream-60">No divisions.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <h3 class="fw-semibold mb-3">Categories</h3>
              <form action="/admin/settings/categories/create" method="post" class="d-flex gap-2 mb-3">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <input class="form-control" name="name" placeholder="e.g. 6-8 years" required />
                <button class="btn btn-outline-light" type="submit">Add</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th style="width: 80px">ID</th>
                      <th>Name</th>
                      <th class="text-end" style="width: 220px">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in categories %}
                    <tr>
                      <td class="text-cream-60">#{{ item.id }}</td>
                      <td class="fw-semibold">{{ item.name }}</td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                          <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editCategoryModal-{{ item.id }}">Edit</button>
                          <form action="/admin/settings/categories/{{ item.id }}/delete" method="post" onsubmit="return confirm('Delete this category?');">
                            <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="3" class="text-cream-60">No categories.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        <section class="panel mb-4">
          <div class="row g-4">
            <div class="col-12 col-lg-6">
              <h3 class="fw-semibold mb-3">Weight Classes</h3>
              <form action="/admin/settings/weight_classes/create" method="post" class="d-flex gap-2 mb-3">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <input class="form-control" name="name" placeholder="e.g. Light Weight: -66 kg (Men), -57 kg (Women)" required />
                <button class="btn btn-outline-light" type="submit">Add</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th style="width: 80px">ID</th>
                      <th>Name</th>
                      <th class="text-end" style="width: 220px">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in weight_classes %}
                    <tr>
                      <td class="text-cream-60">#{{ item.id }}</td>
                      <td class="fw-semibold">{{ item.name }}</td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                          <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editWeightModal-{{ item.id }}">Edit</button>
                          <form action="/admin/settings/weight_classes/{{ item.id }}/delete" method="post" onsubmit="return confirm('Delete this weight class?');">
                            <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="3" class="text-cream-60">No weight classes.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <h3 class="fw-semibold mb-3">Event Definitions</h3>
              <form action="/admin/settings/events/create" method="post" class="d-flex gap-2 mb-3">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <input class="form-control" name="name" placeholder="e.g. Single Live Stick" required />
                <button class="btn btn-outline-light" type="submit">Add</button>
              </form>
              <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                  <thead>
                    <tr>
                      <th style="width: 80px">ID</th>
                      <th>Name</th>
                      <th class="text-end" style="width: 220px">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in events %}
                    <tr>
                      <td class="text-cream-60">#{{ item.id }}</td>
                      <td class="fw-semibold">{{ item.name }}</td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                          <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="modal" data-bs-target="#editEventDefModal-{{ item.id }}">Edit</button>
                          <form action="/admin/settings/events/{{ item.id }}/delete" method="post" onsubmit="return confirm('Delete this event definition?');">
                            <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="3" class="text-cream-60">No events.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        {% for item in divisions %}
        <div class="modal fade" id="editDivisionModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Division #{{ item.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/settings/divisions/{{ item.id }}/update" method="post">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <div class="modal-body">
                  <label class="form-label text-muted">Name</label>
                  <input class="form-control" name="name" value="{{ item.name }}" required />
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}

        {% for item in categories %}
        <div class="modal fade" id="editCategoryModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Category #{{ item.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/settings/categories/{{ item.id }}/update" method="post">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <div class="modal-body">
                  <label class="form-label text-muted">Name</label>
                  <input class="form-control" name="name" value="{{ item.name }}" required />
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}

        {% for item in weight_classes %}
        <div class="modal fade" id="editWeightModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Weight Class #{{ item.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/settings/weight_classes/{{ item.id }}/update" method="post">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <div class="modal-body">
                  <label class="form-label text-muted">Name</label>
                  <input class="form-control" name="name" value="{{ item.name }}" required />
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}

        {% for item in events %}
        <div class="modal fade" id="editEventDefModal-{{ item.id }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Event #{{ item.id }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form action="/admin/settings/events/{{ item.id }}/update" method="post">
                <input type="hidden" name="tournament_id" value="{{ selected_tournament_id }}" />
                <div class="modal-body">
                  <label class="form-label text-muted">Name</label>
                  <input class="form-control" name="name" value="{{ item.name }}" required />
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
        {% endif %}
      </main>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script src="/static/sidebar.js"></script>
  </body>
</html>

